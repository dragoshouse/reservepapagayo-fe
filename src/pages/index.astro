---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import Hero from '../components/Hero.astro';
import VillaCollection from '../components/VillaCollection.astro';
import Experiences from '../components/Experiences.astro';
import Journal from '../components/Journal.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';

const query = `{ "home": *[_type == "home"][0], "settings": *[_type == "siteSettings"][0] }`;
const data = await sanityClient.fetch(query).catch(() => ({}));
---

<Layout title="Experience Papagayo | A Private Peninsula Shaped by Nature">
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <Hero heroData={data?.home?.heroSection} />
      <VillaCollection />
      <Experiences />
      <Journal />
      <CTA />
    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>
