---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import Hero from '../components/Hero.astro';
import VillaCollection from '../components/VillaCollection.astro';
import CuratedExperiences from '../components/CuratedExperiences.astro';
import Journal from '../components/Journal.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../utils/sanity';

const query = `*[_type == "home"][0]{
  ...,
  "videoUrl": heroBackgroundVideo.asset->url,
  curatedExperiences {
    sectionTitle,
    sectionBody,
    experiencesGrid[]->{
      _id,
      title,
      category,
      "imageUrl": image.asset->url,
      description
    }
  },
  sensorialTitle,
  sensorialItalic,
  finalCtaTitle
}`;
const homeData = await sanityClient.fetch(query).catch(() => ({}));

const seoTitle = homeData?.seoTitle ?? "Experience Papagayo | A Private Peninsula Shaped by Nature";
const heroHeadline = homeData?.heroHeadline ?? "A private peninsula shaped by nature";
const heroScrollLabel = homeData?.heroScrollIndicatorLabel ?? "Scroll";
const heroBgUrl = homeData?.heroBackgroundImage ? urlFor(homeData.heroBackgroundImage).url() : null;
const heroVideoUrl = homeData?.videoUrl ?? null;
const villaSectionTitle = homeData?.villaCollectionSectionTitle ?? "Curated Experiences";
const journalLabel = homeData?.journalSectionLabel ?? "Journal";
const journalReadAll = homeData?.journalReadAllLabel ?? "Read All";
const ctaTitle = homeData?.ctaTitle ?? "Your Sanctuary Awaits";
const ctaButtonText = homeData?.ctaButtonText ?? "Inquire Now";
const sensorialTitle = homeData?.sensorialTitle || "Designed for slower mornings, open afternoons, and long evenings.";
const sensorialItalic = homeData?.sensorialItalic || "A stay that feels lived, not staged.";
const finalCtaTitle = homeData?.finalCtaTitle || "Your Place to Be Together";
---

<Layout title={seoTitle}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <Hero
        headline={heroHeadline}
        scrollLabel={heroScrollLabel}
        bgUrl={heroBgUrl}
        videoUrl={heroVideoUrl}
      />

      <!-- Unified Block A & Villa Collection -->
      <section class="bg-black text-white py-32 px-4" data-theme="dark">
        <div class="max-w-4xl mx-auto text-center mb-24">
          <h2 class="text-3xl md:text-5xl font-serif mb-6 text-white">Not all stays are the same.</h2>
          <p class="text-lg text-white/70 font-light">Each stay is shaped around how you travel — your group, your rhythm, your time together.</p>
        </div>

        <div class="max-w-7xl mx-auto">
          <VillaCollection sectionTitle={villaSectionTitle} />
        </div>
      </section>


      <CuratedExperiences sanityData={homeData?.curatedExperiences} />
      <Journal sectionLabel={journalLabel} readAllLabel={journalReadAll} />

      <!-- Block C: Sensorial & Final CTA -->
      <section class="relative bg-black text-white py-40 px-4 flex flex-col items-center justify-center text-center overflow-hidden" data-theme="dark">
        <p class="text-xl md:text-2xl font-light text-white/70 mb-4">
          {sensorialTitle}
        </p>
        <p class="text-xl md:text-2xl italic font-serif text-white/50 mb-16">
          {sensorialItalic}
        </p>
        <h2 class="text-5xl md:text-7xl font-serif text-white mb-20">
          {finalCtaTitle}
        </h2>

        <!-- Magnetic Circular Button -->
        <a href="/contact" class="magnetic-cta relative flex items-center justify-center w-40 h-40 md:w-48 md:h-48 rounded-full border border-white/30 text-white hover:bg-white hover:text-black transition-colors duration-500 group">
          <span class="magnetic-text text-sm tracking-widest uppercase font-medium pointer-events-none">
            Begin Your Stay
          </span>
        </a>
      </section>

    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>

<script>
  import { gsap } from "gsap";

  function initMagneticButtons() {
    const buttons = document.querySelectorAll('.magnetic-cta');

    buttons.forEach((btn) => {
      const text = btn.querySelector('.magnetic-text');

      btn.addEventListener('mousemove', (e) => {
        // e is MouseEvent
        const rect = btn.getBoundingClientRect();
        const h = rect.width / 2;

        // Use type assertion or casting if necessary, but in JS it's fine
        const x = (e as MouseEvent).clientX - rect.left - h;
        const y = (e as MouseEvent).clientY - rect.top - h;

        gsap.to(btn, { x: x * 0.4, y: y * 0.4, duration: 0.5, ease: "power3.out" });
        if (text) gsap.to(text, { x: x * 0.2, y: y * 0.2, duration: 0.5, ease: "power3.out" });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: "elastic.out(1, 0.3)" });
        if (text) gsap.to(text, { x: 0, y: 0, duration: 0.7, ease: "elastic.out(1, 0.3)" });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initMagneticButtons);
  document.addEventListener('astro:page-load', initMagneticButtons);
</script>
