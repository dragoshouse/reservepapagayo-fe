---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 | Experience Papagayo">
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-[#EAE8E1] text-black" data-theme="light">
    <main>
      <section class="flex min-h-[80vh] items-center justify-center px-6 py-28 text-center md:px-12">
        <div class="mx-auto flex max-w-5xl flex-col items-center">
          <p class="error-code font-serif text-8xl leading-none tracking-[-0.08em] text-black opacity-0 md:text-[12rem]">
            404
          </p>
          <h1 class="error-subtitle mt-8 text-sm font-medium uppercase tracking-[0.32em] text-black/60 opacity-0 md:mt-10">
            This space remains undiscovered.
          </h1>
          <a
            href="/"
            class="error-cta group mt-12 inline-flex items-center border border-black/30 px-8 py-4 text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-black opacity-0 transition-colors duration-500 hover:border-black hover:bg-black hover:text-[#EAE8E1] md:mt-14"
          >
            Return to Sanctuary
            <span class="ml-4 h-px w-8 bg-current transition-transform duration-500 group-hover:scale-x-125"></span>
          </a>
        </div>
      </section>
    </main>
  </div>

  <Footer />
  <div id="footer-spacer"></div>
</Layout>

<script>
  import gsap from 'gsap';

  const initNotFoundReveal = () => {
    const elements = gsap.utils.toArray<HTMLElement>('.error-code, .error-subtitle, .error-cta');

    if (!elements.length) return;

    gsap.fromTo(
      elements,
      { y: 28, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1.15,
        ease: 'power3.out',
        stagger: 0.16,
      }
    );
  };

  document.addEventListener('DOMContentLoaded', initNotFoundReveal);
  document.addEventListener('astro:page-load', initNotFoundReveal);
</script>
