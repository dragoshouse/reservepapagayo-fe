---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import AboutHero from '../components/AboutHero.astro';
import AboutManifesto from '../components/AboutManifesto.astro';
import AboutRooted from '../components/AboutRooted.astro';
import AboutLegacy from '../components/AboutLegacy.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../utils/sanity';

let aboutData: any = null;

try {
  const query = `*[_type == "about"][0]{ ..., "heroVideoUrl": heroBackgroundVideo.asset->url }`;
  aboutData = await sanityClient.fetch(query);
} catch (error) {
  console.warn("Failed to fetch Sanity data for about.astro");
}

const seoTitle = aboutData?.seoTitle ?? "About Us | Experience Papagayo";
const heroHeadline = aboutData?.heroHeadline ?? "About Experience Papagayo";
const heroSubheadline = aboutData?.heroSubheadline ?? "We didn't set out to rent villas — we set out to rethink how families experience Costa Rica.";
const heroBgUrl = aboutData?.heroBackgroundImage ? urlFor(aboutData.heroBackgroundImage).url() : null;
const heroVideoUrl = aboutData?.heroVideoUrl ?? null;
const manifestoLines = aboutData?.manifestoLines?.length > 0 ? aboutData.manifestoLines : ["Peninsula Papagayo is one of the most extraordinary places on Earth.", "A private reserve where Pacific sunsets meet jungle canopies.", "But a stunning location alone doesn't create a memorable stay.", "People do."];
const manifestoSupport = aboutData?.manifestoSupportingParagraph ?? "Experience Papagayo was born from a simple belief: that the finest travel is defined not by square footage, but by the quality of care behind every detail.";
const rootedHeading = aboutData?.rootedHeading ?? "Rooted in Peninsula Papagayo. Trusted by discerning travelers worldwide.";
const rootedRawText = aboutData?.rootedDescriptionParagraphs ?? "We operate a curated collection of private homes, designed for space, privacy, and the ease of being together.\n\nBeyond the home, a seamless connection to everything Peninsula Papagayo has to offer.";
const rootedGallery = aboutData?.rootedGalleryImages?.length > 0 ? aboutData.rootedGalleryImages : [];
const legacyHeadline = aboutData?.legacyHeadline ?? "Backed by over 15 years of estate management excellence.";
const legacyParagraph = aboutData?.legacyParagraph ?? "Experience Papagayo is proudly powered by MDO Estate Management...";
const ctaTitle = aboutData?.ctaOverrideTitle ?? "Ready to begin?";
const ctaBtn = aboutData?.ctaOverrideButtonText ?? "Begin Your Stay";
---

<Layout title={seoTitle}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <AboutHero
        headline={heroHeadline}
        subheadline={heroSubheadline}
        bgUrl={heroBgUrl}
        videoUrl={heroVideoUrl}
      />
      <AboutManifesto
        lines={manifestoLines}
        supportText={manifestoSupport}
      />
      <AboutRooted
        heading={rootedHeading}
        rawText={rootedRawText}
        gallery={rootedGallery}
      />
      <AboutLegacy
        headline={legacyHeadline}
        text={legacyParagraph}
      />
      <CTA
        title={ctaTitle}
        buttonText={ctaBtn}
      />
    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>
