---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import AboutHero from '../components/AboutHero.astro';
import AboutManifesto from '../components/AboutManifesto.astro';
import AboutRooted from '../components/AboutRooted.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us | Experience Papagayo">
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <AboutHero />
      <AboutManifesto />
      <AboutRooted />

      <!-- Legacy & Assembly Section -->
      <section class="py-24 md:py-40 px-6 md:px-12 bg-[#111111] text-white flex flex-col items-center justify-center text-center" data-theme="dark">
        <div class="max-w-3xl mx-auto space-y-8">
          <h2 class="font-serif text-3xl md:text-5xl leading-tight">
            Backed by over 15 years of estate management excellence.
          </h2>
          <p class="text-lg md:text-xl font-light text-white/80">
            We've spent over a decade perfecting the art of hospitality on Peninsula Papagayo. Every detail, every interaction, and every moment is designed to exceed expectations.
          </p>
        </div>
      </section>

      <CTA title="Ready to begin?" buttonText="Begin Your Stay" />
    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>
