---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';

let villas = [];
try {
  const villasQuery = '*[_type == "villa" && status == "published"]{ title } | order(title asc)';
  villas = await sanityClient.fetch(villasQuery);
} catch (error) {
  console.error("Failed to fetch villas for contact form dropdown:", error);
}
---

<Layout title="Contact | Experience Papagayo">
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-[#FAF9F6]" data-theme="light">
    <main class="pt-32 md:pt-48 pb-20 px-5 sm:px-6 md:px-12 lg:px-24 min-h-screen flex flex-col justify-center">
      <div class="max-w-4xl mx-auto w-full">
        <!-- Headline -->
        <h1 class="gsap-reveal text-3xl sm:text-4xl md:text-7xl lg:text-8xl font-serif text-slate-900 leading-tight sm:leading-[1.15] mb-12 sm:mb-16 md:mb-20 text-center uppercase tracking-[0.04em] sm:tracking-wide">
          Your Costa Rica Experience<br/>
          <span class="italic font-light lowercase text-2xl sm:text-3xl md:text-6xl lg:text-7xl inline-block mt-2 sm:mt-0">begins with a conversation</span>
        </h1>

        <!-- Form Container -->
        <form id="whatsapp-contact-form" class="max-w-2xl mx-auto space-y-9 sm:space-y-12">
          <!-- Name -->
          <div class="relative gsap-reveal">
            <input type="text" id="name" name="name" class="peer w-full bg-transparent border-b border-gray-300 py-4 text-lg text-slate-900 focus:outline-none focus:border-slate-900 transition-colors placeholder-transparent" placeholder="Name" required />
            <label for="name" class="absolute left-0 -top-3 text-sm text-gray-500 transition-all peer-placeholder-shown:text-lg peer-placeholder-shown:top-4 peer-focus:-top-3 peer-focus:text-sm peer-focus:text-slate-900 pointer-events-none">Name</label>
          </div>

          <!-- Email -->
          <div class="relative gsap-reveal">
            <input type="email" id="email" name="email" class="peer w-full bg-transparent border-b border-gray-300 py-4 text-lg text-slate-900 focus:outline-none focus:border-slate-900 transition-colors placeholder-transparent" placeholder="Email" required />
            <label for="email" class="absolute left-0 -top-3 text-sm text-gray-500 transition-all peer-placeholder-shown:text-lg peer-placeholder-shown:top-4 peer-focus:-top-3 peer-focus:text-sm peer-focus:text-slate-900 pointer-events-none">E-Mail</label>
          </div>

          <!-- Villa of Interest -->
          <div class="relative gsap-reveal">
            <select id="villa" name="villa" class="peer w-full bg-transparent border-b border-gray-300 py-4 text-lg text-slate-900 focus:outline-none focus:border-slate-900 transition-colors cursor-pointer appearance-none" required>
              <option value="" disabled selected>Select a Villa of Interest</option>
              {villas.map((villa) => (
                <option value={villa.title}>{villa.title}</option>
              ))}
            </select>
            <label for="villa" class="absolute left-0 -top-3 text-sm text-gray-500 transition-all peer-focus:-top-3 peer-focus:text-sm peer-focus:text-slate-900 pointer-events-none z-10">Villa of Interest</label>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-slate-900">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>

          <!-- Preferred Dates -->
          <div class="relative gsap-reveal">
            <input type="text" id="date-picker" name="dates" class="peer w-full bg-transparent border-b border-gray-300 py-4 text-lg text-slate-900 focus:outline-none focus:border-slate-900 transition-colors placeholder-transparent cursor-pointer" placeholder="Preferred Dates" required />
            <label for="date-picker" class="absolute left-0 -top-3 text-sm text-gray-500 transition-all peer-placeholder-shown:text-lg peer-placeholder-shown:top-4 peer-focus:-top-3 peer-focus:text-sm peer-focus:text-slate-900 pointer-events-none z-10">Preferred Dates</label>
          </div>

          <!-- Experiences -->
          <div class="relative gsap-reveal">
            <textarea id="experiences" name="experiences" rows="4" class="peer w-full bg-transparent border-b border-gray-300 py-4 text-lg text-slate-900 focus:outline-none focus:border-slate-900 transition-colors placeholder-transparent resize-none" placeholder="What experiences are you dreaming of?"></textarea>
            <label for="experiences" class="absolute left-0 -top-3 text-sm text-gray-500 transition-all peer-placeholder-shown:text-lg peer-placeholder-shown:top-4 peer-focus:-top-3 peer-focus:text-sm peer-focus:text-slate-900 pointer-events-none">What experiences are you dreaming of?</label>
          </div>

          <!-- Submit Button -->
          <div class="pt-6 sm:pt-8 flex flex-col items-center gsap-reveal">
            <button type="submit" class="group relative w-full sm:w-auto px-8 sm:px-12 py-4 rounded-full border border-slate-900 text-slate-900 overflow-hidden transition-colors duration-300 hover:text-white">
              <span class="relative z-10 font-sans tracking-widest text-sm uppercase">Begin Your Stay</span>
              <div class="absolute inset-0 bg-slate-900 translate-y-[101%] group-hover:translate-y-0 transition-transform duration-300 ease-out z-0"></div>
            </button>
          </div>

          <!-- Secondary CTA -->
          <div class="pt-8 sm:pt-12 text-center gsap-reveal flex flex-col items-center">
            <p class="text-sm text-gray-500 mb-4 font-sans tracking-wide">Please contact us directly for immediate assistance</p>
            <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 text-slate-900 hover:opacity-70 transition-opacity">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              <span class="font-sans font-medium uppercase tracking-wider text-sm">Send a message</span>
            </a>
          </div>
        </form>
      </div>
    </main>
  </div>

  <Footer />
  <div id="footer-spacer"></div>

  <script>
    import flatpickr from 'flatpickr';
    import 'flatpickr/dist/flatpickr.min.css';
    import gsap from 'gsap';
    import ScrollTrigger from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const initFlatpickr = () => {
      const dateInput = document.getElementById('date-picker');
      if (dateInput) {
        flatpickr(dateInput, {
          mode: 'range',
          minDate: 'today',
          dateFormat: 'Y-m-d',
          disableMobile: true,
          clickOpens: true,
          allowInput: false
        });
        console.log("Flatpickr successfully mounted");
      } else {
        console.error("Flatpickr target input not found in DOM");
      }
    };

    const initWhatsAppForm = () => {
      const form = document.getElementById('whatsapp-contact-form');
      if (form && !form.dataset.whatsappInit) {
        form.dataset.whatsappInit = 'true';
        form.addEventListener('submit', (e) => {
          e.preventDefault();

          const formData = new FormData(form as HTMLFormElement);
          const name = formData.get('name') || '';
          const email = formData.get('email') || '';
          const villa = formData.get('villa') || '';
          const dates = formData.get('dates') || '';
          const experiences = formData.get('experiences') || '';

          const messageTemplate = `*New Inquiry: Experience Papagayo* 🌴

*Name:* ${name}
*Email:* ${email}
*Villa:* ${villa}
*Dates:* ${dates}

*Experience Details:*
_${experiences}_`;

          const encodedMessage = encodeURIComponent(messageTemplate);
          window.open('https://wa.me/50688603621?text=' + encodedMessage, '_blank');
        });
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      initFlatpickr();
      initWhatsAppForm();

      // GSAP Animations
      const reveals = document.querySelectorAll('.gsap-reveal');

      gsap.fromTo(
        reveals,
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1,
          stagger: 0.15,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '.main-content-wrap',
            start: 'top 80%',
          },
        }
      );
    });

    document.addEventListener('astro:page-load', () => {
      initFlatpickr();
      initWhatsAppForm();
    });
  </script>
</Layout>

<style is:global>
  /* Flatpickr Customization */
  .flatpickr-calendar {
    font-family: inherit !important;
    border: none !important;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important;
    border-radius: 12px !important;
    padding: 10px !important;
    z-index: 9999 !important;
  }

  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange,
  .flatpickr-day.selected.inRange,
  .flatpickr-day.startRange.inRange,
  .flatpickr-day.endRange.inRange,
  .flatpickr-day.selected:focus,
  .flatpickr-day.startRange:focus,
  .flatpickr-day.endRange:focus,
  .flatpickr-day.selected:hover,
  .flatpickr-day.startRange:hover,
  .flatpickr-day.endRange:hover,
  .flatpickr-day.selected.prevMonthDay,
  .flatpickr-day.startRange.prevMonthDay,
  .flatpickr-day.endRange.prevMonthDay,
  .flatpickr-day.selected.nextMonthDay,
  .flatpickr-day.startRange.nextMonthDay,
  .flatpickr-day.endRange.nextMonthDay {
    background: #0f172a !important; /* slate-900 */
    border-color: #0f172a !important;
  }

  .flatpickr-day.inRange,
  .flatpickr-day.prevMonthDay.inRange,
  .flatpickr-day.nextMonthDay.inRange,
  .flatpickr-day.today.inRange,
  .flatpickr-day.prevMonthDay.today.inRange,
  .flatpickr-day.nextMonthDay.today.inRange,
  .flatpickr-day:hover,
  .flatpickr-day.prevMonthDay:hover,
  .flatpickr-day.nextMonthDay:hover,
  .flatpickr-day:focus,
  .flatpickr-day.prevMonthDay:focus,
  .flatpickr-day.nextMonthDay:focus {
    background: #f1f5f9 !important; /* slate-100 */
    border-color: #f1f5f9 !important;
  }

  .flatpickr-current-month .flatpickr-monthDropdown-months,
  .flatpickr-current-month .numInputWrapper {
    font-family: inherit !important;
    font-weight: 500 !important;
  }
</style>
