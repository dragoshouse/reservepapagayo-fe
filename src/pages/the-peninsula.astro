---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FullscreenMenu from '../components/FullscreenMenu.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import fallbackHeroImage from '../assets/pap4336RGB.jpg';
import { sanityClient, urlFor } from '../utils/sanity';

const query = `*[_type == "peninsula"][0]{
  heroTitle,
  heroSubtitle,
  heroImage,
  manifestoText,
  spotlightEyebrow,
  spotlightTitle,
  spotlightBody,
  spotlightImages[]{
    alt,
    image,
    "imageUrl": image.asset->url
  },
  ecosystemTitle,
  ecosystemCards[]{
    title,
    description
  },
  ctaTitle,
  ctaButtonText
}`;

let peninsulaData = null;
try {
  peninsulaData = await sanityClient.fetch(query);
} catch (error) {
  console.error("Error fetching Peninsula data:", error);
}

const fallbackManifestoText =
  'Here, the Pacific Ocean meets untamed jungle canopy. But beyond the staggering beauty lies something rarer: absolute peace of mind. A gated, 1,400-acre private reserve where time slows down and the outside world falls away.';

const fallbackSpotlightImages = [
  {
    imageUrl: 'https://images.unsplash.com/photo-1596436889106-be35e843f974?q=80&w=2000',
    alt: 'Luxury nature resort',
  },
  {
    imageUrl: 'https://images.unsplash.com/photo-1540541338287-41700207dee6?q=80&w=2000',
    alt: 'Untamed jungle canopy',
  },
  {
    imageUrl: 'https://images.unsplash.com/photo-1583417647209-6fa70416cd62?q=80&w=2000',
    alt: 'Pacific Ocean meets the shore',
  },
];

const fallbackEcosystemCards = [
  {
    title: 'Marina Papagayo',
    description: 'A deep-water haven for superyachts.',
  },
  {
    title: 'Arnold Palmer Course',
    description: '18 holes of championship golf over the ocean.',
  },
  {
    title: 'Prieta Bay Beach Club',
    description: 'Exclusive access to pristine sands.',
  },
];

const heroTitle = peninsulaData?.heroTitle ?? 'The Peninsula';
const heroSubtitle = peninsulaData?.heroSubtitle ?? 'More than a destination. A protected sanctuary.';
const spotlightEyebrow = peninsulaData?.spotlightEyebrow ?? 'A Haven for Solo Travelers';
const spotlightTitle = peninsulaData?.spotlightTitle ?? 'Uncompromising Security. Unparalleled Freedom.';
const spotlightBody = peninsulaData?.spotlightBody ?? "Recognized by Travel + Leisure as one of the world's premier destinations for solo travelers, Peninsula Papagayo offers an environment of effortless safety. Whether exploring miles of private trails at dawn or dining under the stars, the implicit promise is absolute security. It is a place where discerning women, families, and solo adventurers find the ultimate luxury: the freedom to simply be.";
const ecosystemTitle = peninsulaData?.ecosystemTitle ?? 'The Ecosystem';
const ctaTitle = peninsulaData?.ctaTitle ?? 'Your Sanctuary Awaits';
const ctaButtonText = peninsulaData?.ctaButtonText ?? 'Inquire Now';

const manifestoText = peninsulaData?.manifestoText?.trim() || fallbackManifestoText;
const manifestoFragments = manifestoText
  .match(/[^.!?]+[.!?]+|[^.!?]+$/g)
  ?.map((fragment) => fragment?.trim())
  ?.filter(Boolean) ?? [fallbackManifestoText];

const sanitySpotlightImages = (peninsulaData?.spotlightImages ?? [])
  .map((image) => ({
    imageUrl: image?.image ? urlFor(image?.image).width(1400).format('webp').quality(85).url() : image?.imageUrl,
    alt: image?.alt ?? spotlightTitle,
  }))
  .filter((image) => image?.imageUrl);

const spotlightImages = sanitySpotlightImages?.length ? sanitySpotlightImages : fallbackSpotlightImages;

const ecosystemCards = (peninsulaData?.ecosystemCards ?? [])
  .map((card) => ({
    title: card?.title ?? '',
    description: card?.description ?? '',
  }))
  .filter((card) => card?.title || card?.description);
const displayEcosystemCards = ecosystemCards?.length ? ecosystemCards : fallbackEcosystemCards;

const heroImageUrl = peninsulaData?.heroImage
  ? urlFor(peninsulaData?.heroImage).width(2400).format('webp').quality(90).url()
  : fallbackHeroImage.src;
---

<Layout title={heroTitle}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <!-- 1. Hero Section -->
      <section class="relative h-screen w-full" data-theme="dark">
        <!-- Background Image -->
        <img
          src={heroImageUrl}
          alt={heroTitle ?? 'The Peninsula Papagayo'}
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent"></div>

        <!-- Content -->
        <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-16 lg:p-24 z-10 text-white">
          <h1 class="text-6xl md:text-8xl lg:text-9xl font-serif mb-4">
            {heroTitle}
          </h1>
          <p class="text-xl md:text-2xl font-light tracking-wide max-w-2xl">
            {heroSubtitle}
          </p>
        </div>
      </section>

      <!-- 2. The Whisper / Manifesto -->
      <section class="min-h-screen flex items-center justify-center px-8 md:px-16 lg:px-24 py-32 bg-[#F9F9F9] text-gray-900" data-theme="light">
        <div class="max-w-5xl mx-auto text-center">
          <p class="text-3xl md:text-5xl lg:text-6xl font-serif leading-relaxed">
            {manifestoFragments.map((fragment) => (
              <span class="gsap-reveal-text block opacity-0 translate-y-8">{fragment}</span>
            ))}
          </p>
        </div>
      </section>

      <!-- 3. The Spotlight (Sticky Scrollytelling) -->
      <section class="min-h-[200vh] bg-white text-gray-900 px-8 md:px-16 lg:px-24" data-theme="light">
        <div class="flex flex-col lg:flex-row max-w-7xl mx-auto w-full relative">

          <!-- Left Column (Sticky) -->
          <div class="lg:w-1/2 lg:sticky lg:top-0 lg:h-screen flex flex-col justify-center lg:pr-12 py-16 lg:py-0">
            <span class="text-sm font-sans tracking-widest uppercase mb-6 text-gray-500">
              {spotlightEyebrow}
            </span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif mb-8 leading-tight">
              {spotlightTitle}
            </h2>
            <p class="text-lg md:text-xl font-light leading-relaxed text-gray-700">
              {spotlightBody}
            </p>
          </div>

          <!-- Right Column (Scrolling Images) -->
          <div class="lg:w-1/2 flex flex-col gap-16 lg:gap-32 py-16 lg:py-32">
            {spotlightImages.map((image, index) => (
              <div class={`w-full ${index % 2 === 1 ? 'aspect-[4/3]' : 'aspect-[3/4]'} overflow-hidden`}>
                <img
                  src={image?.imageUrl ?? fallbackHeroImage.src}
                  alt={image?.alt ?? spotlightTitle ?? 'Peninsula Papagayo'}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>

        </div>
      </section>

      <!-- 4. The Ecosystem -->
      <section class="py-32 px-8 md:px-16 lg:px-24 bg-[#1A1A1A] text-white" data-theme="dark">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif mb-16 text-center">
            {ecosystemTitle}
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
            {displayEcosystemCards.map((card) => (
              <div class="flex flex-col border-t border-white/20 pt-8">
                <h3 class="text-2xl font-serif mb-4">{card?.title ?? 'Papagayo'}</h3>
                <p class="text-white/70 font-light leading-relaxed">
                  {card?.description ?? 'A private sanctuary shaped by nature, service, and quiet luxury.'}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <CTA
        title={ctaTitle}
        buttonText={ctaButtonText}
      />
    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    const revealElements = document.querySelectorAll('.gsap-reveal-text');

    if (revealElements.length === 0) return;

    revealElements.forEach((el) => {
      gsap.to(el, {
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
        },
        y: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power3.out',
      });
    });
  }

  // Run on initial load
  document.addEventListener('DOMContentLoaded', initAnimations);

  // Re-run on Astro page transitions
  document.addEventListener('astro:page-load', initAnimations);
</script>
