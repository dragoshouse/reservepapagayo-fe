---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FullscreenMenu from '../../components/FullscreenMenu.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../../utils/sanity';

type SanityGalleryItem = {
  url?: string | null;
  alt?: string | null;
  caption?: string | null;
  credit?: string | null;
};

type SanityVilla = {
  title?: string | null;
  slug: string;
  heroTitle?: string | null;
  heroKicker?: string | null;
  heroMediaType?: string | null;
  heroBgUrl?: string | null;
  heroVideoUrl?: string | null;
  heroBackgroundImage?: unknown;
  overviewEyebrow?: string | null;
  overviewManifesto?: string | null;
  overviewShort?: string | null;
  gallery?: SanityGalleryItem[] | null;
  bedrooms?: number | null;
  bathrooms?: number | null;
  maxGuests?: number | null;
  interiorSqFt?: number | null;
  exteriorSqFt?: number | null;
  amenities?: string[] | null;
  highlightAmenities?: string[] | null;
  locationZone?: string | null;
  startingPrice?: number | null;
};

export async function getStaticPaths() {
  const query = `*[_type == "villa"]{
    "slug": slug.current,
    title, heroTitle, heroKicker, heroMediaType,
    "heroBgUrl": heroBackgroundImage.asset->url,
    "heroVideoUrl": heroBackgroundVideo.asset->url,
    overviewEyebrow, overviewManifesto, overviewShort,
    "gallery": galleryItems[]{ "url": image.asset->url, "alt": image.alt, caption, credit },
    bedrooms, bathrooms, maxGuests, interiorSqFt, exteriorSqFt,
    amenities, highlightAmenities, locationZone, startingPrice,
    heroBackgroundImage
  }`;

  let villas: SanityVilla[] = [];
  try {
    villas = await sanityClient.fetch<SanityVilla[]>(query, {}, { useCdn: false });
  } catch (error) {
    console.error('Error fetching villas:', error);
  }

  if (villas.length === 0) {
    villas = [
      {
        slug: 'villa-esmeralda',
        title: 'Villa Esmeralda',
        heroTitle: 'Villa Esmeralda',
        overviewManifesto: 'A private sanctuary crafted for restorative escapes.',
        locationZone: 'Papagayo Peninsula',
        startingPrice: 5000,
        bedrooms: 6,
        bathrooms: 8,
        maxGuests: 12,
        interiorSqFt: 12000,
        amenities: ['Private Infinity Pool', 'Dedicated Chef', 'Home Cinema', 'Ocean Views'],
        gallery: [
          { url: 'https://via.placeholder.com/800x600', caption: 'Poolside', credit: 'Photo by Studio' },
          { url: 'https://via.placeholder.com/800x600', caption: 'Living Room', credit: 'Photo by Studio' }
        ]
      }
    ];
  }

  return villas.map((villa) => ({
    params: { slug: villa.slug },
    props: {
      villa: {
        ...villa,
        heroBgUrl: villa.heroBgUrl ?? (villa.heroBackgroundImage ? urlFor(villa.heroBackgroundImage).url() : null)
      }
    }
  }));
}

const { villa } = Astro.props as { villa: SanityVilla };

const title = villa.title ?? 'Villa';
const heroBgUrl = villa.heroBgUrl ?? null;
const heroVideoUrl = villa.heroVideoUrl ?? null;

const overviewEyebrow = villa.overviewEyebrow ?? 'At a Glance';
const overviewManifesto = villa.overviewManifesto ?? villa.overviewShort ?? 'A private sanctuary crafted for restorative escapes.';

const gallery = villa.gallery ?? [];
const galleryCount = gallery.length;

const bedrooms = villa.bedrooms ?? null;
const bathrooms = villa.bathrooms ?? null;
const maxGuests = villa.maxGuests ?? null;
const interiorSqFt = villa.interiorSqFt ?? null;
const amenities = villa.amenities ?? [];
const locationZone = villa.locationZone ?? 'Papagayo';
const startingPrice = villa.startingPrice ?? null;
const formattedStartingPrice =
  startingPrice !== null ? `$${new Intl.NumberFormat('en-US').format(startingPrice)}` : null;
---

<Layout title={`${title} | Experience Papagayo`}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <!-- STEP 1: HERO & WHISPER -->
      <section class="villa-hero relative h-screen w-full overflow-hidden flex items-center justify-center" data-theme="dark">
        <div class="absolute inset-0 w-full h-full">
          {heroVideoUrl ? (
            <video class="w-full h-full object-cover" src={heroVideoUrl} autoplay muted loop playsinline></video>
          ) : (
            heroBgUrl && (
              <img
                src={heroBgUrl}
                alt={title}
                class="w-full h-full object-cover scale-[1.05]"
                loading="eager"
              />
            )
          )}
          <div class="absolute inset-0 bg-black/25"></div>
        </div>

        <div class="relative z-10 text-center px-4 max-w-5xl">
          <h1 class="villa-title text-6xl md:text-[8vw] font-serif text-[#F5F5F0] tracking-tight leading-[0.8] opacity-0 translate-y-10">
            {title}
          </h1>
        </div>
      </section>

      <section class="villa-overview py-32 md:py-48 px-6 md:px-12 bg-white flex items-center justify-center min-h-[50vh]" data-theme="light">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-xs tracking-[0.2em] uppercase font-bold text-black/40 mb-10">{overviewEyebrow}</h2>
          <p class="villa-manifesto-text text-3xl md:text-5xl lg:text-6xl font-serif leading-tight md:leading-snug text-[#1A1A1A] opacity-0 translate-y-8">
            {overviewManifesto}
          </p>
        </div>
      </section>

      <!-- STEP 4: GOD-TIER HORIZONTAL GALLERY & LIGHTBOX -->
      <section class="villa-gallery py-16 md:py-24 bg-[#F8F7F3] overflow-hidden" data-theme="light">
        <div class="px-6 md:px-12 mb-12 flex justify-between items-end">
          <h2 class="text-xs tracking-[0.2em] uppercase font-bold text-black/40">Gallery</h2>
          <div class="flex items-center gap-4">
            <button id="gallery-prev" class="w-10 h-10 flex items-center justify-center border border-black/10 rounded-full hover:bg-black hover:text-white transition-colors" aria-label="Previous image">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button id="gallery-next" class="w-10 h-10 flex items-center justify-center border border-black/10 rounded-full hover:bg-black hover:text-white transition-colors" aria-label="Next image">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
        </div>
        <div class="px-6 md:px-12">
          <div class="flex gap-6 overflow-x-auto pb-8 snap-x snap-mandatory no-scrollbar gallery-container">
            {gallery.map((item, index) => {
              const displayIndex = (index + 1).toString().padStart(2, '0');
              const totalIndex = galleryCount.toString().padStart(2, '0');

              return (
                <figure class="min-w-[85vw] md:min-w-[60vw] lg:min-w-[45vw] snap-start relative group cursor-pointer gallery-image-trigger" key={`${item.url ?? 'image'}-${index}`} data-src={item.url ?? ''}>
                  <div class="overflow-hidden relative h-[40rem] w-full rounded-sm">
                    <img
                      src={item.url ?? ''}
                      alt={item.alt ?? `${title} gallery image ${index + 1}`}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  </div>

                  <figcaption class="mt-4 flex flex-col md:flex-row md:items-center justify-between gap-2 border-t border-black/10 pt-4">
                    <div class="text-xs font-serif uppercase tracking-widest text-black/80">
                      {displayIndex} / {totalIndex}
                    </div>
                    <div class="text-sm text-black/60 flex items-center gap-4">
                      {item.caption && <span class="italic">{item.caption}</span>}
                      {item.credit && <span class="uppercase text-[0.65rem] tracking-[0.2em] text-black/40">{item.credit}</span>}
                    </div>
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      </section>

      <!-- STEP 2: THE "SWISS BLUEPRINT" SPECS BOX -->
      <section class="villa-specs py-20 md:py-28 px-6 md:px-12 bg-white" data-theme="light">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-xs tracking-[0.2em] uppercase font-bold text-black/40 mb-12 text-center">Specifications</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-black/10 border border-black/10">
            {/* 3x2 Grid - 6 Items */}
            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Location Zone</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{locationZone}</p>
            </div>

            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Starting Price</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{formattedStartingPrice ?? '—'}</p>
            </div>

            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Bedrooms</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{bedrooms ?? '—'}</p>
            </div>

            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Bathrooms</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{bathrooms ?? '—'}</p>
            </div>

            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Max Guests</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{maxGuests ?? '—'}</p>
            </div>

            <div class="bg-white p-8 lg:p-12 flex flex-col justify-between aspect-square md:aspect-auto">
              <p class="text-xs uppercase tracking-[0.18em] text-black/45">Interior SqFt</p>
              <p class="mt-4 text-3xl lg:text-4xl font-serif text-black">{interiorSqFt ? `${interiorSqFt} sq ft` : '—'}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- STEP 3: "THE AMENITIES SHOWCASE" -->
      {amenities.length > 0 && (
        <section class="villa-amenities py-24 md:py-32 bg-[#F9F7F3]" data-theme="light">
          <div class="max-w-6xl mx-auto px-6 md:px-12">
            <h2 class="text-4xl md:text-5xl font-serif text-center text-black mb-16 md:mb-24">The Amenities</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-8">
              {amenities.map((amenity, index) => (
                <div class="border-b border-black/10 pb-4 flex items-center justify-between group" key={`${amenity}-${index}`}>
                  <span class="text-lg text-black/80 font-light group-hover:text-black transition-colors">{amenity ?? ''}</span>
                  <span class="text-black/20 text-xs tracking-widest">+</span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <CTA title={`Experience <br/>${title}`} buttonText="Reserve" />
    </main>
  </div>

  <Footer />
  <div id="footer-spacer"></div>

  <!-- LIGHTBOX MODAL -->
  <div id="gallery-lightbox" class="fixed inset-0 z-[99999] flex items-center justify-center opacity-0 pointer-events-none" style="backdrop-filter: blur(0px);">
    <div class="absolute inset-0 bg-black/90 lightbox-bg"></div>

    <!-- Controls -->
    <button id="lightbox-close" class="absolute top-8 right-8 text-white z-[100] w-12 h-12 flex items-center justify-center text-xl hover:scale-110 transition-transform" aria-label="Close lightbox">
      &#x2715;
    </button>

    <button id="lightbox-prev" class="absolute top-1/2 -translate-y-1/2 left-8 text-white z-[100] w-12 h-12 flex items-center justify-center hover:scale-110 transition-transform cursor-pointer" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>

    <button id="lightbox-next" class="absolute top-1/2 -translate-y-1/2 right-8 text-white z-[100] w-12 h-12 flex items-center justify-center hover:scale-110 transition-transform cursor-pointer" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <div id="lightbox-counter" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/80 text-sm tracking-widest font-serif z-[100]">
      1 / 1
    </div>

    <div class="relative z-10 w-full max-w-7xl px-4 flex justify-center lightbox-content scale-110">
      <img id="lightbox-img" src="" alt="Gallery Fullscreen" class="max-h-[85vh] w-auto object-contain" />
    </div>
  </div>
</Layout>

<script>
  import { gsap } from 'gsap';

  function initVillaTemplate() {
    const title = document.querySelector('.villa-title');
    if (title) {
      gsap.to(title, {
        opacity: 1,
        y: 0,
        duration: 1.5,
        ease: 'power3.out',
        delay: 0.2
      });
    }

    const manifesto = document.querySelector('.villa-manifesto-text');
    if (manifesto) {
      gsap.to(manifesto, {
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: 'power3.out',
        delay: 0.1
      });
    }

    // Inline Gallery Logic
    const galleryContainer = document.querySelector('.gallery-container');
    const galleryPrev = document.getElementById('gallery-prev');
    const galleryNext = document.getElementById('gallery-next');

    if (galleryContainer && galleryPrev && galleryNext) {
      galleryPrev.addEventListener('click', () => {
        galleryContainer.scrollBy({ left: -(window.innerWidth * 0.5), behavior: 'smooth' });
      });
      galleryNext.addEventListener('click', () => {
        galleryContainer.scrollBy({ left: window.innerWidth * 0.5, behavior: 'smooth' });
      });
    }

    // Lightbox Logic
    const galleryImages = Array.from(document.querySelectorAll('.gallery-image-trigger'));
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    const lightboxCounter = document.getElementById('lightbox-counter');
    const lightboxContent = document.querySelector('.lightbox-content');

    let isLightboxOpen = false;
    let currentIndex = 0;

    function updateCounter() {
      if (lightboxCounter) {
        lightboxCounter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
      }
    }

    function openLightbox(index: number) {
      if (!lightbox || !lightboxImg || !lightboxContent) return;

      currentIndex = index;
      const src = galleryImages[currentIndex].getAttribute('data-src');
      if (!src) return;

      lightboxImg.src = src;
      updateCounter();
      isLightboxOpen = true;

      // Prevent scrolling
      document.body.style.overflow = 'hidden';

      // Make visible and pointer events active
      lightbox.classList.remove('pointer-events-none');

      // GSAP Animation
      gsap.to(lightbox, {
        opacity: 1,
        backdropFilter: 'blur(10px)',
        duration: 0.5,
        ease: 'power3.out'
      });

      gsap.to(lightboxContent, {
        scale: 1,
        duration: 0.6,
        ease: 'back.out(1.2)'
      });
    }

    function changeSlide(direction: number) {
      if (!lightboxImg || !isLightboxOpen) return;

      // Modulo math to loop around safely
      currentIndex = (currentIndex + direction + galleryImages.length) % galleryImages.length;
      const newSrc = galleryImages[currentIndex].getAttribute('data-src');
      if (!newSrc) return;

      // Crossfade using GSAP
      gsap.to(lightboxImg, {
        opacity: 0,
        duration: 0.2,
        onComplete: () => {
          lightboxImg.src = newSrc;
          updateCounter();
          gsap.to(lightboxImg, {
            opacity: 1,
            duration: 0.2
          });
        }
      });
    }

    function closeLightbox() {
      if (!lightbox || !lightboxContent) return;
      isLightboxOpen = false;

      // Restore scrolling
      document.body.style.overflow = '';

      // Reverse GSAP Animation
      gsap.to(lightboxContent, {
        scale: 1.1,
        duration: 0.4,
        ease: 'power3.in'
      });

      gsap.to(lightbox, {
        opacity: 0,
        backdropFilter: 'blur(0px)',
        duration: 0.4,
        ease: 'power3.in',
        onComplete: () => {
          lightbox.classList.add('pointer-events-none');
          if (lightboxImg) lightboxImg.src = '';
        }
      });
    }

    galleryImages.forEach((item, index) => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        openLightbox(index);
      });
    });

    if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
    if (lightboxPrev) lightboxPrev.addEventListener('click', () => changeSlide(-1));
    if (lightboxNext) lightboxNext.addEventListener('click', () => changeSlide(1));

    // Close on background click
    const lightboxBg = document.querySelector('.lightbox-bg');
    if (lightboxBg) {
      lightboxBg.addEventListener('click', closeLightbox);
    }

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!isLightboxOpen) return;

      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') changeSlide(-1);
      if (e.key === 'ArrowRight') changeSlide(1);
    });
  }

  document.addEventListener('astro:page-load', initVillaTemplate);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initVillaTemplate();
  } else {
    document.addEventListener('DOMContentLoaded', initVillaTemplate);
  }
</script>

<style is:global>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
