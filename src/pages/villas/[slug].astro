---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FullscreenMenu from '../../components/FullscreenMenu.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../../utils/sanity';

type SanityVilla = {
  title: string;
  slug: string;
  heroBackgroundImage: unknown;
  locationZone: string | null;
  bedrooms: number | null;
  bathrooms: number | null;
};

export async function getStaticPaths() {
  const query = `*[_type == "villa" && status == "published"] | order(_createdAt desc) {
    title,
    "slug": slug.current,
    heroBackgroundImage,
    locationZone,
    bedrooms,
    bathrooms
  }`;

  const villas = await sanityClient.fetch<SanityVilla[]>(query);

  return villas.map((villa) => ({
    params: { slug: villa.slug },
    props: {
      villa: {
        ...villa,
        imageUrl: villa.heroBackgroundImage ? urlFor(villa.heroBackgroundImage).url() : null
      }
    }
  }));
}

const { villa } = Astro.props;
---

<Layout title={`${villa.title} | Experience Papagayo`}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <main>
      <section class="villa-hero relative h-screen w-full overflow-hidden flex items-center justify-center" data-theme="dark">
        <div class="absolute inset-0 w-full h-full">
          {villa.imageUrl && (
            <img
              src={villa.imageUrl}
              alt={villa.title}
              class="w-full h-full object-cover scale-[1.05]"
              loading="eager"
            />
          )}
          <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/20 to-black/60"></div>
        </div>

        <div class="relative z-10 text-center px-4">
          <h1 class="villa-title text-6xl md:text-[8vw] font-serif text-[#F5F5F0] tracking-tight leading-none opacity-0 translate-y-10">
            {villa.title}
          </h1>
        </div>
      </section>

      <section class="villa-overview py-32 md:py-48 px-6 md:px-12 bg-white flex items-center justify-center min-h-[50vh]" data-theme="light">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-sm tracking-[0.2em] uppercase font-bold text-black/40 mb-12">At a Glance</h2>
          <p class="villa-manifesto-text text-3xl md:text-5xl lg:text-6xl font-serif leading-tight md:leading-snug text-[#1A1A1A]">
            {villa.locationZone ?? 'Papagayo'} · {(villa.bedrooms ?? '—')} Bedrooms · {(villa.bathrooms ?? '—')} Bathrooms
          </p>
        </div>
      </section>

      <CTA title={`Experience <br/>${villa.title}`} buttonText="Reserve" />
    </main>
  </div>

  <Footer />
  <div id="footer-spacer"></div>
</Layout>

<script>
  import { gsap } from 'gsap';

  function initVillaTemplate() {
    const title = document.querySelector('.villa-title');
    if (title) {
      gsap.to(title, {
        opacity: 1,
        y: 0,
        duration: 1.5,
        ease: 'power3.out',
        delay: 0.2
      });
    }
  }

  document.addEventListener('astro:page-load', initVillaTemplate);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initVillaTemplate();
  } else {
    document.addEventListener('DOMContentLoaded', initVillaTemplate);
  }
</script>
