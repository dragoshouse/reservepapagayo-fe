---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FullscreenMenu from '../../components/FullscreenMenu.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient } from 'sanity:client';

type SanityVilla = {
  title: string;
  slug: string;
  imageUrl?: string | null;
  overviewShort?: string | null;
};

const query = `*[_type == "villa"]{
  title,
  "slug": slug.current,
  "imageUrl": coalesce(
    heroImage.asset->url, 
    heroPosterImage.asset->url,
    galleryItems[0].image.asset->url
  ),
  overviewShort
}`;

const villas = await sanityClient.fetch<SanityVilla[]>(query);
---

<Layout title="The Villas | Experience Papagayo">
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-[#F6F2E9] text-[#171717]">
    <main class="pt-32 md:pt-44">
      <header class="max-w-[95%] mx-auto pb-20 md:pb-28">
        <p class="mb-8 text-[11px] uppercase tracking-[0.45em] text-black/45">Private Residences</p>
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.5fr)] lg:items-end">
          <h1 class="font-serif text-6xl leading-[0.9] tracking-[-0.04em] text-[#171717] md:text-8xl lg:text-[9vw]">
            Villas<br />Collection
          </h1>
          <p class="max-w-md text-sm leading-relaxed text-black/60 md:text-base">
            A restrained edit of private Papagayo sanctuaries shaped by architecture, landscape, and the quiet rhythm of coastal living.
          </p>
        </div>
      </header>

      <section data-theme="light" class="max-w-[95%] mx-auto py-24">
        {villas.length === 0 ? (
          <div class="flex min-h-[40vh] items-center justify-center border-y border-black/10">
            <p class="text-sm uppercase tracking-[0.35em] text-black/45">Curating our exclusive collection...</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-x-12 gap-y-24 md:grid-cols-2 lg:grid-cols-3">
            {villas.map((villa, index) => (
              <a href={`/villas/${villa.slug}`} class="villa-card group block" aria-label={`Discover ${villa.title}`}>
                <figure>
                  <div class="relative aspect-[4/5] overflow-hidden bg-black/5">
                    {villa.imageUrl ? (
                      <img
                        src={villa.imageUrl}
                        alt={villa.title}
                        class="h-full w-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
                        loading={index === 0 ? 'eager' : 'lazy'}
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-[#E7E0D2] text-[10px] uppercase tracking-[0.35em] text-black/35">
                        Image Pending
                      </div>
                    )}

                    <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-colors duration-700 group-hover:bg-black/30">
                      <span class="text-sm uppercase tracking-[0.3em] text-white opacity-0 transition-opacity duration-700 group-hover:opacity-100">
                        DISCOVER
                      </span>
                    </div>
                  </div>

                  <figcaption class="mt-8">
                    <h2 class="text-lg uppercase tracking-widest text-[#171717]">
                      {villa.title}
                    </h2>
                    <p class="mt-4 line-clamp-3 text-sm leading-relaxed text-black/70">
                      {villa.overviewShort?.trim() || 'A quietly composed private residence within the Papagayo landscape.'}
                    </p>
                    <p class="mt-6 text-[10px] uppercase tracking-widest text-black/50">
                      ARCHITECTURE | RESIDENTIAL | COSTA RICA
                    </p>
                  </figcaption>
                </figure>
              </a>
            ))}
          </div>
        )}
      </section>

      <CTA title="Curate Your <br class='hidden md:block'/>Escape" buttonText="Inquire" />
    </main>
  </div>

  <Footer />
  <div id="footer-spacer"></div>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initVillaArchiveReveal() {
    const cards = gsap.utils.toArray<HTMLElement>('.villa-card');

    if (!cards.length) return;

    gsap.set(cards, { y: 50, opacity: 0 });

    ScrollTrigger.batch(cards, {
      start: 'top 88%',
      once: true,
      onEnter: (batch) => {
        gsap.to(batch, {
          y: 0,
          opacity: 1,
          duration: 1.2,
          ease: 'expo.out',
          stagger: 0.12,
          overwrite: true
        });
      }
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initVillaArchiveReveal);

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initVillaArchiveReveal();
  } else {
    document.addEventListener('DOMContentLoaded', initVillaArchiveReveal);
  }
</script>
