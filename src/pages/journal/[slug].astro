---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FullscreenMenu from '../../components/FullscreenMenu.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const journalEntries = await getCollection('journal');

  // Sort entries to easily find the "next" article
  const sortedEntries = journalEntries.sort((a, b) =>
    b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return sortedEntries.map((entry, index) => {
    // Logic for "next" article in the list (loop back to 0 if at the end)
    const nextEntry = index < sortedEntries.length - 1
      ? sortedEntries[index + 1]
      : sortedEntries[0];

    return {
      params: { slug: entry.slug },
      props: { entry, nextEntry },
    };
  });
}

const { entry, nextEntry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={`${entry.data.title} | Experience Papagayo Journal`}>
  <Header />
  <FullscreenMenu />

  <div class="main-content-wrap relative z-10 bg-white">
    <!-- STEP 1: THE READING PROGRESS BAR -->
    <div class="fixed top-0 left-0 w-full h-[1px] bg-slate-900 z-50 origin-left scale-x-0" id="reading-progress"></div>

    <main>
    <!-- STEP 2: THE EDITORIAL HERO -->
    <header class="relative w-full mb-24 md:mb-32">
      <!-- Image Container with overflow hidden for parallax -->
      <div class="w-full h-[60vh] md:h-[80vh] overflow-hidden">
        <Image
          src={entry.data.coverImage}
          alt={entry.data.title}
          width={2000}
          class="w-full h-full object-cover scale-110"
          id="hero-image"
        />
      </div>

      <!-- Spacious Header Content -->
      <div class="max-w-5xl mx-auto px-6 pt-16 md:pt-24 text-center">
        <div class="hero-content opacity-0 translate-y-8">
          <p class="text-xs md:text-sm tracking-[0.2em] uppercase font-sans mb-6 md:mb-8 text-slate-500">
            {formattedDate}
          </p>
          <h1 class="font-serif font-normal text-5xl md:text-7xl lg:text-8xl leading-[1.1] text-slate-900 mb-8 md:mb-12">
            {entry.data.title}
          </h1>
          <p class="font-sans text-lg md:text-2xl text-slate-600 max-w-2xl mx-auto font-light leading-relaxed">
            {entry.data.description}
          </p>
        </div>
      </div>
    </header>

    <!-- STEP 3: THE CONTENT BODY -->
    <article class="max-w-2xl mx-auto px-6 mb-32 md:mb-48 editorial-content">
      <div class="prose prose-slate prose-headings:font-serif prose-headings:font-normal prose-p:font-sans prose-p:leading-relaxed prose-p:text-slate-800 prose-img:rounded-none prose-img:w-full prose-a:underline prose-a:decoration-1">
        <Content />
      </div>
    </article>

    <!-- STEP 4: THE "NEXT STORY" FOOTER -->
    <section class="w-full bg-slate-50 py-32 md:py-48 px-6 flex items-center justify-center">
      <a href={`/journal/${nextEntry.slug}`} class="group block text-center max-w-4xl mx-auto">
        <p class="text-xs md:text-sm tracking-[0.2em] uppercase font-sans mb-8 text-slate-500 group-hover:text-slate-900 transition-colors duration-500">
          Read Next
        </p>
        <h2 class="font-serif font-normal text-4xl md:text-6xl lg:text-7xl text-slate-900 group-hover:opacity-70 transition-opacity duration-500">
          {nextEntry.data.title}
        </h2>
      </a>
    </section>

    <!-- STEP 5: CTA -->
    <CTA />
    </main>
  </div>

  <Footer />
  <!-- Spacer for the fixed footer to reveal naturally -->
  <div id="footer-spacer"></div>
</Layout>

<style is:global>
  /* Contrast styling for header elements against the hero image */
  header#site-header.absolute.top-0 {
    mix-blend-mode: difference;
    color: white;
  }
  /* Editorial Drop Cap for the first letter of the first paragraph */
  .editorial-content .prose > p:first-of-type::first-letter {
    float: left;
    font-family: 'Cormorant Garamond', ui-serif, Georgia, serif;
    font-size: 6.5rem;
    line-height: 0.7;
    padding-top: 0.12em;
    padding-right: 0.1em;
    padding-left: 0;
    margin-bottom: -0.2em;
    color: #0f172a; /* text-slate-900 */
    font-weight: 400;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Make sure we run client-side only
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    // Give the DOM a tiny moment to ensure Lenis and layout are ready
    setTimeout(() => {
      // 1. Reading Progress Bar
      gsap.to('#reading-progress', {
        scaleX: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: true, // Smooth scrubbing
        }
      });

      // 2. Parallax Hero Image (move image up slower than the container scrolls)
      // The image starts a bit scaled (1.1) to allow room for parallax movement
      gsap.to('#hero-image', {
        yPercent: 15,
        ease: 'none',
        scrollTrigger: {
          trigger: 'header',
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        }
      });

      // 3. Fade up Hero Content on Load
      gsap.to('.hero-content', {
        y: 0,
        opacity: 1,
        duration: 1.5,
        ease: 'power3.out',
        delay: 0.1, // Slight delay for elegance
      });

      // Optional: Refresh ScrollTrigger after animations setup
      ScrollTrigger.refresh();
    }, 100);
  }
</script>
