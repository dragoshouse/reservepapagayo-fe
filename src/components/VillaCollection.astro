---
import { sanityClient } from 'sanity:client';
import { urlFor } from '../utils/sanity';

const { sectionTitle = 'Villa Collection' }: { sectionTitle?: string } = Astro.props;

type SanityVilla = {
  title: string;
  slug: string;
  heroBackgroundImage: unknown;
  locationZone: string | null;
  bedrooms: number | null;
  bathrooms: number | null;
  maxGuests: number | null;
  overviewShort: string | null;
};

const query = `*[_type == "villa"] | order(_createdAt desc) {
  title,
  "slug": slug.current,
  heroBackgroundImage,
  locationZone,
  bedrooms,
  bathrooms,
  maxGuests,
  overviewShort
}`;

let villas: any[] = [];
try {
  villas = (await sanityClient.fetch<SanityVilla[]>(query)).map((villa) => ({
    ...villa,
    imageUrl: villa.heroBackgroundImage ? urlFor(villa.heroBackgroundImage).url() : null
  }));
} catch (e) {
  console.warn("Sanity fetch failed for VillaCollection, using fallbacks.");
}

const formatBathrooms = (value: number | null) => {
  if (value === null || Number.isNaN(value)) return '—';
  return Number.isInteger(value) ? `${value}` : `${value}`;
};
---

<section id="villa-collection-section" class="relative isolate w-full overflow-x-hidden bg-black py-20 md:py-28" data-theme="dark">
  <h2 class="sr-only">{sectionTitle}</h2>

  {villas.length === 0 ? (
    <section class="flex min-h-[60vh] w-full items-center justify-center bg-black px-6 py-32">
      <p class="text-center text-xl font-light tracking-wide text-white/50">Curating our exclusive collection...</p>
    </section>
  ) : (
    <div id="villa-collection-shell" class="relative left-1/2 w-screen -translate-x-1/2">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-black via-black/70 to-transparent md:w-32"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-black via-black/70 to-transparent md:w-32"></div>

      <button
        type="button"
        class="villa-nav villa-nav-prev group absolute left-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-black/35 text-white/85 backdrop-blur-md transition duration-300 hover:border-white/60 hover:bg-white hover:text-black focus:outline-none focus:ring-2 focus:ring-white/70 disabled:pointer-events-none disabled:opacity-25 md:left-12 md:h-14 md:w-14"
        aria-label="Scroll villa collection left"
        data-villa-prev
      >
        <svg class="h-5 w-5 transition-transform duration-300 group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div
        id="villa-track"
        class="no-scrollbar flex w-full snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-4 py-4 sm:gap-6 md:gap-8 md:px-12 lg:gap-10"
        data-villa-track
        tabindex="0"
        aria-label="Scrollable villa collection"
      >
        {villas.map((villa, index) => (
          <a
            href={`/villas/${villa.slug}`}
            class="villa-card group relative block h-[min(72vh,680px)] min-h-[430px] w-[84vw] flex-none snap-start overflow-hidden rounded-none bg-zinc-900 outline-none transition duration-500 hover:-translate-y-1 focus-visible:ring-2 focus-visible:ring-white/80 sm:w-[64vw] md:h-[min(74vh,720px)] md:min-h-[540px] md:w-[44vw] lg:w-[34vw] xl:w-[30vw]"
            data-index={index}
          >
            <div class="villa-image-wrapper absolute inset-0 rounded-none">
              {villa.imageUrl && (
                <img
                  src={villa.imageUrl}
                  alt={villa.title}
                  class="h-full w-full scale-105 object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  loading="lazy"
                />
              )}
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-transparent opacity-95 transition-opacity duration-500 group-hover:opacity-100"></div>
            <div class="absolute inset-x-0 bottom-0 z-10 max-h-full overflow-hidden p-6 text-white sm:p-7 md:p-8 lg:p-10">
              <div class="flex min-h-0 flex-col justify-end">
                <span class="mb-3 block text-base text-white/60 transition-transform duration-300 group-hover:translate-y-1 md:mb-4 md:text-lg">↓</span>
                <h3 class="villa-title font-serif text-[clamp(2rem,8vw,3.5rem)] leading-[0.95] tracking-[-0.03em] text-white md:text-[clamp(2.75rem,4vw,4.75rem)]">
                  {villa.title}
                </h3>

                <p class="mt-4 w-full border-b border-white/20 pb-4 text-[0.68rem] uppercase tracking-[0.18em] text-white/80 md:mt-5 md:text-sm">
                  {villa.bedrooms ?? '—'} bedrooms &middot; {villa.maxGuests ?? '12-16'} guests
                </p>

                <p class="villa-summary mt-4 max-w-sm text-sm font-light leading-relaxed text-white/75 md:mt-5 md:text-base">
                  {villa.overviewShort ?? 'A private sanctuary offering unparalleled views and quiet luxury.'}
                </p>

                <span class="mt-6 flex items-center text-xs uppercase tracking-[0.24em] text-white/90 transition-colors duration-300 group-hover:text-white md:mt-8 md:text-sm">
                  <span class="mr-3">Discover</span>
                  <svg class="h-4 w-8 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 40 16" fill="none" aria-hidden="true">
                    <path d="M1 8H37" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"></path>
                    <path d="M31 2L37 8L31 14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <button
        type="button"
        class="villa-nav villa-nav-next group absolute right-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-black/35 text-white/85 backdrop-blur-md transition duration-300 hover:border-white/60 hover:bg-white hover:text-black focus:outline-none focus:ring-2 focus:ring-white/70 disabled:pointer-events-none disabled:opacity-25 md:right-12 md:h-14 md:w-14"
        aria-label="Scroll villa collection right"
        data-villa-next
      >
        <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  )}
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .villa-card {
    border-radius: 0;
  }

  .villa-title,
  .villa-summary {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .villa-title {
    -webkit-line-clamp: 3;
  }

  .villa-summary {
    -webkit-line-clamp: 3;
  }

  @media (max-width: 420px) {
    .villa-card {
      min-height: 400px;
    }

    .villa-summary {
      -webkit-line-clamp: 2;
    }
  }
</style>

<script>
  const initVillaCollection = () => {
    const track = document.querySelector<HTMLElement>('[data-villa-track]');
    const prev = document.querySelector<HTMLButtonElement>('[data-villa-prev]');
    const next = document.querySelector<HTMLButtonElement>('[data-villa-next]');

    if (!track || !prev || !next || track.dataset.sliderReady === 'true') return;

    track.dataset.sliderReady = 'true';

    const getScrollDistance = () => window.innerWidth * 0.5;
    const maxScrollLeft = () => Math.max(0, track.scrollWidth - track.clientWidth - 1);

    const updateControls = () => {
      const canScroll = track.scrollWidth > track.clientWidth + 1;
      prev.hidden = !canScroll;
      next.hidden = !canScroll;

      if (!canScroll) return;

      prev.disabled = track.scrollLeft <= 1;
      next.disabled = track.scrollLeft >= maxScrollLeft();
    };

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollDistance(), behavior: 'smooth' });
    });

    next.addEventListener('click', () => {
      track.scrollBy({ left: getScrollDistance(), behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateControls, { passive: true });
    window.addEventListener('resize', updateControls);
    updateControls();
  };

  document.addEventListener('astro:page-load', initVillaCollection);

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initVillaCollection();
  } else {
    document.addEventListener('DOMContentLoaded', initVillaCollection);
  }
</script>
