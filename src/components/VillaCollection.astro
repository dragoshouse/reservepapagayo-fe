---
import { sanityClient } from 'sanity:client';
import { urlFor } from '../utils/sanity';

const { sectionTitle = 'Villa Collection' }: { sectionTitle?: string } = Astro.props;

type SanityVilla = {
  title: string;
  slug: string;
  heroBackgroundImage: unknown;
  locationZone: string | null;
  bedrooms: number | null;
  bathrooms: number | null;
  maxGuests: number | null;
  overviewShort: string | null;
};

const query = `*[_type == "villa"] | order(_createdAt desc) {
  title,
  "slug": slug.current,
  heroBackgroundImage,
  locationZone,
  bedrooms,
  bathrooms,
  maxGuests,
  overviewShort
}`;

let villas: any[] = [];
try {
  villas = (await sanityClient.fetch<SanityVilla[]>(query)).map((villa) => ({
    ...villa,
    imageUrl: villa.heroBackgroundImage ? urlFor(villa.heroBackgroundImage).url() : null
  }));
} catch (e) {
  console.warn("Sanity fetch failed for VillaCollection, using fallbacks.");
}

const formatBathrooms = (value: number | null) => {
  if (value === null || Number.isNaN(value)) return '—';
  return Number.isInteger(value) ? `${value}` : `${value}`;
};
---

<section id="villa-collection-section" class="relative h-screen w-full overflow-hidden bg-black" data-theme="dark">
  <h2 class="sr-only">{sectionTitle}</h2>

  {villas.length === 0 ? (
    <section class="w-full bg-black py-32 flex items-center justify-center">
      <p class="text-xl text-white/50 font-light tracking-wide">Curating our exclusive collection...</p>
    </section>
  ) : (
    <div id="villa-pin-container" class="h-screen w-full flex items-center overflow-hidden">
      <div id="villa-track" class="flex flex-nowrap w-[max-content] h-[85vh] items-center px-[5vw] md:px-[10vw] gap-12 md:gap-24">
        {villas.map((villa, index) => (
          <a
            href={`/villas/${villa.slug}`}
            class="villa-card relative w-[85vw] md:w-[35vw] flex-shrink-0 cursor-pointer group block flex flex-col justify-start items-start"
            data-index={index}
          >
            <div class="w-full aspect-[4/5] relative overflow-hidden mb-8">
              <div class="villa-image-wrapper absolute inset-0 w-full h-full scale-[1.1]">
                {villa.imageUrl && (
                  <img
                    src={villa.imageUrl}
                    alt={villa.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                )}
              </div>
            </div>

            <div class="w-full flex flex-col justify-start text-white">
              <span class="text-white/60 text-lg mb-4 block group-hover:translate-y-1 transition-transform duration-300">↓</span>
              <h3 class="text-white font-serif text-3xl md:text-5xl leading-tight mb-4">
                {villa.title}
              </h3>

              <p class="text-white/80 text-xs md:text-sm tracking-[0.18em] uppercase mb-6 border-b border-white/20 pb-4 w-full">
                {villa.bedrooms ?? '—'} bedrooms &middot; {villa.maxGuests ?? '12-16'} guests
              </p>

              <p class="text-white/70 text-sm md:text-base mb-8 max-w-sm font-light">
                {villa.overviewShort ?? 'A private sanctuary offering unparalleled views and quiet luxury.'}
              </p>

              <span class="flex items-center text-white/90 text-sm tracking-widest uppercase group-hover:text-white transition-colors duration-300">
                <span class="mr-3">→ Discover</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('villa-collection-section');
  const track = document.getElementById('villa-track');
  const cards = document.querySelectorAll('.villa-card');

  if (section && track && cards.length > 0) {
    gsap.to(track, {
      x: () => -(track.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: section,
        pin: true,
        scrub: 1,
        start: 'top top',
        end: () => `+=${track.scrollWidth - window.innerWidth}`,
        invalidateOnRefresh: true
      }
    });

    cards.forEach((card) => {
      const imageWrapper = card.querySelector('.villa-image-wrapper');

      if (imageWrapper) {
        gsap.to(imageWrapper, {
          xPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: () => `+=${track.scrollWidth - window.innerWidth}`,
            scrub: true
          }
        });
      }
    });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${track.scrollWidth - window.innerWidth}`,
      onUpdate: () => {
        const viewportCenter = window.innerWidth / 2;

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const distance = Math.abs(viewportCenter - cardCenter);
          const threshold = rect.width;

          let progress = 1 - distance / threshold;
          progress = Math.max(0, Math.min(1, progress));

          const scale = 1 + 0.02 * progress;
          const opacity = 0.5 + 0.5 * progress;

          gsap.set(card, {
            scale,
            opacity
          });
        });
      }
    });

    gsap.set(cards, { opacity: 0.5, scale: 1 });
  }
</script>
