---
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero-bg.jpg';
---

<section id="about-hero" class="relative h-screen w-full overflow-hidden bg-black flex items-center justify-center" data-theme="dark">
  <div class="absolute inset-0 z-0 h-[120%] w-full" data-about-hero-bg>
    <Picture
      src={heroImage}
      alt="Experience Papagayo - About Us"
      formats={['avif', 'webp']}
      class="absolute inset-0 object-cover w-full h-full opacity-80"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Top dark gradient overlay for header contrast -->
  <div class="absolute top-0 left-0 w-full h-1/3 bg-gradient-to-b from-black/60 to-transparent z-10 pointer-events-none"></div>

  <div class="relative z-20 text-center px-4 max-w-4xl mx-auto flex flex-col items-center">
    <h1
      class="text-white font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-tight opacity-0 translate-y-8 mb-8"
      data-about-hero-element
    >
      About Experience Papagayo
    </h1>
    <p class="text-white/90 text-lg md:text-xl lg:text-2xl font-light max-w-2xl opacity-0 translate-y-8" data-about-hero-element>
      We didn't set out to rent villas. We set out to change how people experience Costa Rica.
    </p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade-up animation for the headline and text
  gsap.to('[data-about-hero-element]', {
    y: 0,
    opacity: 1,
    duration: 1.5,
    ease: 'power3.out',
    delay: 0.2,
    stagger: 0.2
  });

  // Parallax effect for the background image
  gsap.to('[data-about-hero-bg]', {
    yPercent: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#about-hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true
    }
  });
</script>
