---
interface Props {
  headline?: string;
  text?: string;
}

const {
  headline = "Backed by over 15 years of estate management excellence.",
  text = "We've spent over a decade perfecting the art of hospitality on Peninsula Papagayo. Every detail, every interaction, and every moment is designed to exceed expectations."
} = Astro.props;
---

<section class="py-24 md:py-40 px-6 md:px-12 bg-[#111111] text-white flex flex-col items-center justify-center text-center" data-theme="dark">
  <div class="max-w-3xl mx-auto space-y-8">
    <h2 class="font-serif text-3xl md:text-5xl leading-tight">
      {headline}
    </h2>
    <p class="text-lg md:text-xl font-light text-white/80">
      {text}
    </p>
  </div>
</section>
