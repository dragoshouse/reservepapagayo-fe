---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allJournalPosts = await getCollection('journal');

const articles = allJournalPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<section class="journal-section py-32 px-4 md:px-12 bg-white relative overflow-hidden" id="journal" data-theme="light">
  <div class="max-w-7xl mx-auto relative z-10">
    <header class="mb-16 md:mb-24 flex justify-between items-end border-b border-black/10 pb-8">
      <h2 class="text-xs tracking-[0.2em] uppercase font-medium">Journal</h2>
      <a href="#" class="text-sm border-b border-black pb-1 hover:text-black/60 transition-colors">Read All</a>
    </header>

    <div class="journal-list flex flex-col relative group/list" role="list">
      {articles.map((article, index) => (
        <article class="journal-item group/item cursor-pointer border-b border-black/5 py-8 md:py-12 relative z-10 transition-opacity duration-500 hover:!opacity-100 group-hover/list:opacity-30" data-index={index}>
          <a href={`/journal/${article.slug}`} class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 w-full">
            <h3 class="font-serif text-4xl md:text-6xl lg:text-7xl xl:text-8xl tracking-tight group-hover/item:italic transition-all duration-500 origin-left">
              {article.data.title}
            </h3>
            {article.data.category && (
              <span class="text-xs uppercase tracking-widest text-black/40 group-hover/item:text-black transition-colors duration-300">
                {article.data.category}
              </span>
            )}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
