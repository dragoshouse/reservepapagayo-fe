---
import { Picture } from 'astro:assets';
import expSpa from '../assets/exp-spa.jpg';
import expCulinary from '../assets/exp-culinary.jpg';
import expFamily from '../assets/exp-family.jpg';

const categories = ['Family Activities', 'Culinary', 'Wellness & Spa', 'Adventures', 'Golf'];
---

<section class="py-24 md:py-32 bg-white" id="experiences">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="mb-16 text-center">
      <h2 class="font-serif text-4xl md:text-5xl text-slate-900 mb-4 opacity-0 translate-y-8" data-exp-header>Curated Experiences</h2>
      <p class="text-slate-600 max-w-2xl mx-auto opacity-0 translate-y-4" data-exp-subheader>Immerse yourself in a world of bespoke adventures designed to connect you with the vibrant essence of Costa Rica.</p>
    </div>

    <!-- Masonry-style Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-16">
      <!-- Image 1 -->
      <div class="md:col-span-7 h-80 md:h-[500px] overflow-hidden group rounded-lg" data-exp-img>
        <div class="w-full h-full transition-transform duration-1000 group-hover:scale-105">
          <Picture
            src={expFamily}
            alt="Family Activities"
            formats={['avif', 'webp']}
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- Right Column (stacked on md) -->
      <div class="md:col-span-5 grid grid-rows-2 gap-6">
        <!-- Image 2 -->
        <div class="h-64 md:h-[238px] overflow-hidden group rounded-lg" data-exp-img>
          <div class="w-full h-full transition-transform duration-1000 group-hover:scale-105">
            <Picture
              src={expCulinary}
              alt="Culinary Experiences"
              formats={['avif', 'webp']}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <!-- Image 3 -->
        <div class="h-64 md:h-[238px] overflow-hidden group rounded-lg" data-exp-img>
          <div class="w-full h-full transition-transform duration-1000 group-hover:scale-105">
            <Picture
              src={expSpa}
              alt="Wellness & Spa"
              formats={['avif', 'webp']}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Scrollable Pill Navigation -->
    <div class="relative w-full overflow-hidden">
      <!-- Gradient masks for fading edges -->
      <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none md:hidden"></div>
      <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none md:hidden"></div>

      <div class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory hide-scrollbar md:justify-center" data-exp-nav>
        {categories.map((category, index) => (
          <button
            class={`flex-none snap-center px-6 py-2.5 rounded-full border border-slate-300 font-sans text-sm tracking-wide transition-colors duration-300 ${index === 0 ? 'bg-slate-900 text-white border-slate-900' : 'bg-transparent text-slate-700 hover:border-slate-500'}`}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: '#experiences',
      start: 'top 75%',
    }
  });

  tl.to('[data-exp-header]', {
    y: 0,
    opacity: 1,
    duration: 0.8,
    ease: 'power3.out'
  })
  .to('[data-exp-subheader]', {
    y: 0,
    opacity: 1,
    duration: 0.8,
    ease: 'power3.out'
  }, '-=0.6')
  .fromTo('[data-exp-img]',
    { opacity: 0, y: 30 },
    {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.15,
      ease: 'power3.out'
    },
    '-=0.4'
  )
  .fromTo('[data-exp-nav]',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out'},
    '-=0.5'
  );
</script>
