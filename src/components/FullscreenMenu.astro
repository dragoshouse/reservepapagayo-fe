---
import bgThePeninsula from '../assets/hero-bg.jpg';
import { sanityClient } from '../utils/sanity';

const menuQuery = `*[_type == "siteSettings"][0]{
  mainMenu[]{
    label,
    link,
    "imageUrl": hoverImage.asset->url
  }
}`;

const fallbackMenuImage = bgThePeninsula.src;
const fallbackNavItems = [
  { label: 'Villa Collection', href: '/villas', imageUrl: fallbackMenuImage },
  { label: 'The Peninsula', href: '/the-peninsula', imageUrl: fallbackMenuImage },
  { label: 'About Us', href: '/about', imageUrl: fallbackMenuImage },
  { label: 'Contact', href: '/contact', imageUrl: fallbackMenuImage },
];

let siteSettings = null;
try {
  siteSettings = await sanityClient.fetch(menuQuery);
} catch (error) {
  console.error('Error fetching fullscreen menu settings:', error);
}

const optimizeSanityImageUrl = (imageUrl) => {
  if (!imageUrl) return fallbackMenuImage;

  const separator = imageUrl.includes('?') ? '&' : '?';
  return `${imageUrl}${separator}w=2200&auto=format&q=85`;
};

const sanitizedMainMenu = (siteSettings?.mainMenu ?? [])
  .map((item) => ({
    label: item?.label ?? '',
    href: item?.link ?? '',
    imageUrl: optimizeSanityImageUrl(item?.imageUrl),
  }))
  .filter((item) => item?.label && item?.href);

const navItems = sanitizedMainMenu?.length ? sanitizedMainMenu : fallbackNavItems;
---

<div id="fullscreen-menu" class="fixed inset-0 z-[100] w-full h-full overflow-hidden opacity-0 invisible pointer-events-none">
  <!-- Background Images Layer -->
  <div class="absolute inset-0 w-full h-full bg-black">
    {navItems.map((item, index) => (
      <div class="absolute inset-0 w-full h-full overflow-hidden menu-bg-container">
        <img
          src={item?.imageUrl ?? fallbackMenuImage}
          alt={item?.label ?? 'Experience Papagayo'}
          class="w-full h-full object-cover opacity-0 menu-bg-image"
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          data-index={index}
        />
      </div>
    ))}
  </div>

  <!-- Overlay to darken the background images slightly for better text readability -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Close Button -->
  <button id="menu-close" class="absolute top-6 right-6 md:top-12 md:right-12 z-[110] text-white font-sans text-sm tracking-[0.2em] uppercase cursor-pointer opacity-0 pointer-events-none focus:outline-none" style="pointer-events: auto;">
    Close
  </button>

  <!-- Content Layer -->
  <div class="relative z-10 w-full h-full flex flex-col items-center justify-center">
    <nav class="flex flex-col items-center space-y-6 md:space-y-10">
      {navItems.map((item, index) => (
        <div class="overflow-hidden">
          <a
            href={item?.href ?? '/'}
            class="menu-link block text-4xl md:text-7xl lg:text-8xl text-white font-serif tracking-wide transition-[font-style] duration-500 hover:italic opacity-0 translate-y-full"
            data-index={index}
          >
            {item?.label ?? 'Experience Papagayo'}
          </a>
        </div>
      ))}
    </nav>
  </div>
</div>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('fullscreen-menu');
    const links = document.querySelectorAll('.menu-link');
    const bgImages = document.querySelectorAll('.menu-bg-image');
    const hamburgerLines = document.querySelectorAll('#menu-toggle span');
    const menuClose = document.getElementById('menu-close');

    let isMenuOpen = false;

    // Timeline for menu open/close
    const tl = gsap.timeline({ paused: true });

    // Initial state setup for clip path
    gsap.set(menu, { clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
    if (bgImages[0]) {
      gsap.set(bgImages[0], { opacity: 0.6, scale: 1 }); // Default background
    }

    // Menu Reveal Animation
    tl.to(menu, {
      clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)',
      duration: 1.2,
      ease: 'power4.inOut',
      onStart: () => {
        gsap.set(menu, { autoAlpha: 1 });
        menu.classList.remove('pointer-events-none');
        menu.classList.add('pointer-events-auto');
        if (window.lenis) window.lenis.stop(); // Stop scroll
      },
      onReverseComplete: () => {
        gsap.set(menu, { autoAlpha: 0 });
        menu.classList.add('pointer-events-none');
        menu.classList.remove('pointer-events-auto');
        if (window.lenis) window.lenis.start(); // Start scroll
      }
    })
    // Links entrance
    .to(links, {
      y: '0%',
      opacity: 1,
      duration: 1,
      stagger: 0.1,
      ease: 'power3.out'
    }, '-=0.6')
    // Close button entrance
    .to(menuClose, {
      autoAlpha: 1,
      duration: 0.5,
      ease: 'power2.out'
    }, '-=0.5');

    // Hamburger icon animation timeline
    const hamburgerTl = gsap.timeline({ paused: true });
    hamburgerTl
      .to(hamburgerLines[0], { y: 3.75, rotation: 45, duration: 0.3, ease: 'power2.inOut' }, 0)
      .to(hamburgerLines[1], { y: -3.75, rotation: -45, duration: 0.3, ease: 'power2.inOut' }, 0);

    // Toggle menu
    menuToggle?.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;
      if (isMenuOpen) {
        tl.play();
        hamburgerTl.play();
      } else {
        tl.reverse();
        hamburgerTl.reverse();
      }
    });

    // Close menu via Close button
    menuClose?.addEventListener('click', () => {
      isMenuOpen = false;
      tl.reverse();
      hamburgerTl.reverse();
    });

    // Hover effect on links
    let activeIndex = 0; // The first item is default

    links.forEach((link) => {
      link.addEventListener('mouseenter', (e) => {
        const index = parseInt((e.target as HTMLElement).dataset.index || '0');

        if (index === activeIndex || !bgImages[index] || !bgImages[activeIndex]) return;

        // Fade out previous image
        gsap.to(bgImages[activeIndex], {
          opacity: 0,
          scale: 1,
          duration: 0.8,
          ease: 'power2.inOut'
        });

        // Fade in new image and slowly scale it up
        gsap.fromTo(bgImages[index],
          { opacity: 0, scale: 1 },
          {
            opacity: 0.6,
            scale: 1.05,
            duration: 2,
            ease: 'power1.out',
            overwrite: 'auto'
          }
        );

        activeIndex = index;
      });
    });
  });
</script>
