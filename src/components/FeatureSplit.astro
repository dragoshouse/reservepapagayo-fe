---
import { Picture } from 'astro:assets';
import featureImage from '../assets/feature-villa.jpg';
---

<section class="py-24 md:py-32 px-6 md:px-12 max-w-7xl mx-auto" id="collection">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-center">
    <!-- Left Column: Image -->
    <div class="relative w-full aspect-[4/5] overflow-hidden" data-feature-img-container>
      <div class="absolute inset-0 origin-bottom" data-feature-mask></div>
      <div class="h-[120%] w-full" data-feature-img>
        <Picture
          src={featureImage}
          alt="Exclusive Private Sanctuary in Papagayo"
          formats={['avif', 'webp']}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Right Column: Text & Button -->
    <div class="flex flex-col space-y-8" data-feature-text-container>
      <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-tight">
        <span class="block overflow-hidden"><span class="block translate-y-full" data-feature-text-line>Where serenity</span></span>
        <span class="block overflow-hidden"><span class="block translate-y-full" data-feature-text-line>meets untouched</span></span>
        <span class="block overflow-hidden"><span class="block translate-y-full" data-feature-text-line>wilderness.</span></span>
      </h2>

      <p class="text-slate-600 text-lg md:text-xl font-sans max-w-md leading-relaxed overflow-hidden">
        <span class="block translate-y-full opacity-0" data-feature-text-desc>
          Discover our exclusive collection of oceanfront villas, seamlessly integrated into the lush landscape of the Papagayo peninsula.
        </span>
      </p>

      <div class="pt-4 overflow-hidden">
        <a
          href="#villas"
          class="inline-block px-8 py-4 border border-slate-900 text-slate-900 font-sans text-sm tracking-widest uppercase hover:bg-slate-900 hover:text-white transition-colors duration-300 translate-y-full opacity-0"
          data-feature-btn
        >
          Private Villas Collection
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Set up clip path mask for image reveal
  gsap.set('[data-feature-mask]', {
    backgroundColor: '#f8fafc', // match bg-slate-50
    height: '100%',
    transformOrigin: 'top',
    zIndex: 10
  });

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: '#collection',
      start: 'top 70%',
    }
  });

  // Reveal image by animating mask scaleY to avoid layout thrashing
  tl.to('[data-feature-mask]', {
    scaleY: 0,
    duration: 1.5,
    ease: 'power3.inOut'
  });

  // Slight parallax on image while scrolling
  gsap.to('[data-feature-img]', {
    yPercent: -20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#collection',
      start: 'top bottom',
      end: 'bottom top',
      scrub: true
    }
  });

  // Stagger text lines
  tl.to('[data-feature-text-line]', {
    y: 0,
    duration: 1,
    stagger: 0.1,
    ease: 'power4.out'
  }, '-=0.8');

  // Fade in description and button
  tl.to(['[data-feature-text-desc]', '[data-feature-btn]'], {
    y: 0,
    opacity: 1,
    duration: 0.8,
    stagger: 0.1,
    ease: 'power3.out'
  }, '-=0.6');
</script>
