---
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero-bg-new.webp';
---

<section id="hero" class="relative h-screen w-full overflow-hidden bg-black flex items-center justify-center" data-theme="dark">
  <div class="absolute inset-0 z-0 h-[120%] w-full" data-hero-bg>
    <Picture
      src={heroImage}
      alt="Exclusive coastal view in Papagayo"
      formats={['avif', 'webp']}
      class="absolute inset-0 object-cover w-full h-full opacity-80"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Top dark gradient overlay for header contrast -->
  <div class="absolute top-0 left-0 w-full h-1/3 bg-gradient-to-b from-black/60 to-transparent z-10 pointer-events-none"></div>

  <div class="relative z-20 text-center px-4 max-w-4xl">
    <h1
      class="text-white font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-tight opacity-0 translate-y-8"
      data-hero-headline
    >
      A private peninsula shaped by nature
    </h1>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-4" data-scroll-indicator>
    <span class="text-white/80 text-[10px] tracking-[0.3em] uppercase font-sans">Scroll</span>
    <div class="w-[1px] h-16 bg-white/20 relative overflow-hidden">
      <div class="w-full h-full bg-white origin-top" data-scroll-line></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade-up animation for the headline
  gsap.to('[data-hero-headline]', {
    y: 0,
    opacity: 1,
    duration: 1.5,
    ease: 'power3.out',
    delay: 0.2
  });

  // Parallax effect for the background image
  gsap.to('[data-hero-bg]', {
    yPercent: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true
    }
  });

  // Scroll Indicator Animation Loop
  gsap.fromTo('[data-scroll-line]',
    { scaleY: 0 },
    {
      scaleY: 1,
      duration: 1.5,
      ease: 'power2.inOut',
      repeat: -1,
      yoyo: true
    }
  );

  // Fade out Scroll Indicator on page scroll
  gsap.to('[data-scroll-indicator]', {
    opacity: 0,
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: '+=200',
      scrub: true
    }
  });
</script>
