---
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero-bg-new.webp';

const { headline, scrollLabel, bgUrl, videoUrl } = Astro.props;
---

<section id="hero" class="relative h-screen w-full overflow-hidden bg-black flex items-center justify-center" data-theme="dark">
  <div class="absolute inset-0 z-0 h-[120%] w-full" data-hero-bg>
    {videoUrl ? (
      <video src={videoUrl} autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover" />
    ) : bgUrl ? (
      <img src={bgUrl} alt="Hero Background" class="absolute inset-0 w-full h-full object-cover" />
    ) : (
      <Picture
        src={heroImage}
        alt="Exclusive coastal view in Papagayo"
        formats={['avif', 'webp']}
        class="absolute inset-0 object-cover w-full h-full opacity-80"
        loading="eager"
        fetchpriority="high"
      />
    )}
  </div>

  <!-- Cinematic Overlay System: Subtle Vignette + Text Scrim -->
  <!-- Layer 1: Global Vignette for edge darkening -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_50%,_rgba(0,0,0,0.3)_100%)] z-10 pointer-events-none"></div>

  <!-- Layer 2: Targeted Text Scrim for contrast without full dimming -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-black/85 via-black/30 to-transparent z-10 pointer-events-none"></div>

  <div class="relative z-20 text-center px-4 max-w-4xl">
    <h1
      class="text-white font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-tight opacity-0 translate-y-8 [text-shadow:_0_5px_30px_rgb(0_0_0_/_60%)]"
      data-hero-headline
    >
      {headline}
    </h1>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-4" data-scroll-indicator>
    <span class="text-white/80 text-[10px] tracking-[0.3em] uppercase font-sans">{scrollLabel}</span>
    <div class="w-[1px] h-16 bg-white/20 relative overflow-hidden">
      <div class="w-full h-full bg-white origin-top" data-scroll-line></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade-up animation for the headline
  gsap.to('[data-hero-headline]', {
    y: 0,
    opacity: 1,
    duration: 1.5,
    ease: 'power3.out',
    delay: 0.2
  });

  // Parallax effect for the background image
  gsap.to('[data-hero-bg]', {
    yPercent: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true
    }
  });

  // Scroll Indicator Animation Loop
  gsap.fromTo('[data-scroll-line]',
    { scaleY: 0 },
    {
      scaleY: 1,
      duration: 1.5,
      ease: 'power2.inOut',
      repeat: -1,
      yoyo: true
    }
  );

  // Fade out Scroll Indicator on page scroll
  gsap.to('[data-scroll-indicator]', {
    opacity: 0,
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: '+=200',
      scrub: true
    }
  });
</script>
