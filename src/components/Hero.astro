---
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero-bg-new.webp';

const { headline, scrollLabel, bgUrl, videoUrl } = Astro.props;
---

<section id="hero" class="relative h-screen w-full overflow-hidden bg-black flex items-center justify-center" data-theme="dark">
  <div class="absolute inset-0 z-0 h-[120%] w-full" data-hero-bg>
    {videoUrl ? (
      <video src={videoUrl} autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover" />
    ) : bgUrl ? (
      <img src={bgUrl} alt="Hero Background" class="absolute inset-0 w-full h-full object-cover" />
    ) : (
      <Picture
        src={heroImage}
        alt="Exclusive coastal view in Papagayo"
        formats={['avif', 'webp']}
        class="absolute inset-0 object-cover w-full h-full opacity-80"
        loading="eager"
        fetchpriority="high"
      />
    )}
  </div>

  <div class="absolute inset-0 w-full h-full bg-black/25 z-10 pointer-events-none"></div>

  <div class="relative z-20 text-center px-4 max-w-4xl flex flex-col items-center">
    <h1 class="text-white font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-tight opacity-0 translate-y-8" data-hero-headline>
      A private peninsula shaped by nature<br/>
      <span class="text-sm tracking-widest uppercase mt-4 block font-sans">Peninsula Papagayo, Costa Rica</span>
    </h1>
    <p class="text-white/80 font-light text-lg md:text-xl mt-6 font-serif opacity-0 translate-y-8" data-hero-subtitle>
      Spaces shaped by landscape, light, and quiet intention.
    </p>
    <a href="/villas" class="inline-block border border-white text-white px-8 py-3 mt-8 text-sm uppercase tracking-widest hover:bg-white hover:text-black transition-colors duration-300 opacity-0 translate-y-8" data-hero-cta>
      → View availability
    </a>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-4" data-scroll-indicator>
    <span class="text-white/80 text-[10px] tracking-[0.3em] uppercase font-sans">{scrollLabel}</span>
    <div class="w-[1px] h-16 bg-white/20 relative overflow-hidden">
      <div class="w-full h-full bg-white origin-top" data-scroll-line></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade-up animation for the headline, subtitle, and CTA
  gsap.to(['[data-hero-headline]', '[data-hero-subtitle]', '[data-hero-cta]'], {
    y: 0,
    opacity: 1,
    duration: 1.5,
    ease: 'power3.out',
    stagger: 0.2,
    delay: 0.2
  });

  // Parallax effect for the background image
  gsap.to('[data-hero-bg]', {
    yPercent: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true
    }
  });

  // Scroll Indicator Animation Loop
  gsap.fromTo('[data-scroll-line]',
    { scaleY: 0 },
    {
      scaleY: 1,
      duration: 1.5,
      ease: 'power2.inOut',
      repeat: -1,
      yoyo: true
    }
  );

  // Fade out Scroll Indicator on page scroll
  gsap.to('[data-scroll-indicator]', {
    opacity: 0,
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: '+=200',
      scrub: true
    }
  });
</script>
