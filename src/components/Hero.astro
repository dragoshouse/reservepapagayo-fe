---
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero-bg.jpg';
---

<section id="hero" class="relative h-screen w-full overflow-hidden bg-black flex items-center justify-center">
  <!-- Top dark gradient overlay for header contrast -->
  <div class="absolute top-0 left-0 w-full h-32 md:h-48 bg-gradient-to-b from-black/60 to-transparent z-20 pointer-events-none"></div>

  <div class="absolute inset-0 z-0 h-[120%] w-full" data-hero-bg>
    <Picture
      src={heroImage}
      alt="Exclusive coastal view in Papagayo"
      formats={['avif', 'webp']}
      class="h-full w-full object-cover opacity-80"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl">
    <h1
      class="text-white font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight leading-tight opacity-0 translate-y-8"
      data-hero-headline
    >
      A private peninsula shaped by nature
    </h1>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade-up animation for the headline
  gsap.to('[data-hero-headline]', {
    y: 0,
    opacity: 1,
    duration: 1.5,
    ease: 'power3.out',
    delay: 0.2
  });

  // Parallax effect for the background image
  gsap.to('[data-hero-bg]', {
    yPercent: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true
    }
  });
</script>
