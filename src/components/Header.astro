---
import { Image } from 'astro:assets';
import logoMain from '../assets/logo-main.png';
import logoArena from '../assets/logo-arena.png';
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 py-6 md:px-12 bg-transparent border-b border-transparent transition-colors duration-300">
  <div class="flex items-center h-16 md:h-24">
    <a href="/" class="relative block h-full w-auto hover:opacity-80 transition-opacity">
      <div id="logo-wrapper" class="relative block h-full w-auto origin-left transition-transform duration-300">
        <div id="logo-main-container" class="h-full transition-opacity duration-300">
          <Image src={logoMain} alt="Experience Papagayo" class="h-full w-auto object-contain" />
        </div>
        <div id="logo-arena-container" class="absolute left-0 top-0 h-full w-full opacity-0 pointer-events-none transition-opacity duration-300">
          <Image src={logoArena} alt="Experience Papagayo" class="h-full w-auto object-contain" />
        </div>
      </div>
    </a>
  </div>

  <button id="menu-toggle" aria-label="Menu" class="flex flex-col items-center justify-center w-10 h-10 space-y-1.5 focus:outline-none group">
    <span class="menu-line block w-6 h-[1px] bg-white origin-center transition-colors"></span>
    <span class="menu-line block w-6 h-[1px] bg-white origin-center transition-colors"></span>
  </button>
</header>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const header = document.getElementById("site-header");
  const logoWrapper = document.getElementById("logo-wrapper");
  const logoMain = document.getElementById("logo-main-container");
  const logoArena = document.getElementById("logo-arena-container");
  const menuLines = document.querySelectorAll(".menu-line");

  if (header && logoWrapper && logoMain && logoArena) {
    // 1. Sticky Header Behavior
    ScrollTrigger.create({
      start: "top -50",
      end: 99999,
      toggleClass: {className: "is-sticky", targets: header},
      onEnter: () => {
        // Sticky State: White bg, smaller padding, scale down logo
        gsap.to(header, { backgroundColor: "#ffffff", borderBottomColor: "rgba(0,0,0,0.1)", paddingTop: "1rem", paddingBottom: "1rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 0.75, duration: 0.3, ease: "power2.out" });

        // Hide Main Logo
        gsap.to(logoMain, { opacity: 0, duration: 0.3 });

        // Show Arena Logo
        gsap.to(logoArena, { opacity: 1, duration: 0.3 });

        gsap.to(menuLines, { backgroundColor: "#000000", duration: 0.3 });
      },
      onLeaveBack: () => {
        // Start State: Transparent bg, normal padding, normal logo size
        gsap.to(header, { backgroundColor: "transparent", borderBottomColor: "transparent", paddingTop: "1.5rem", paddingBottom: "1.5rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 1, duration: 0.3, ease: "power2.out" });

        // Hide Arena Logo
        gsap.to(logoArena, { opacity: 0, duration: 0.3 });

        // Show Main Logo
        gsap.to(logoMain, { opacity: 1, duration: 0.3 });

        gsap.to(menuLines, { backgroundColor: "#ffffff", duration: 0.3 });
      }
    });

    // 2. Villa Collection Reversion Behavior
    ScrollTrigger.create({
      trigger: "#villa-collection-section",
      start: "top 50px", // When the section reaches near the top (where header is)
      end: "bottom top", // When the section leaves the viewport
      onEnter: () => {
        // Revert header to transparent, hide Arena logo, show Main logo
        gsap.to(header, { backgroundColor: "transparent", borderBottomColor: "transparent", paddingTop: "1.5rem", paddingBottom: "1.5rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 1, duration: 0.3, ease: "power2.out" });
        gsap.to(logoArena, { opacity: 0, duration: 0.3 });
        gsap.to(logoMain, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#ffffff", duration: 0.3 });
      },
      onLeave: () => {
        // Return to sticky state (white background, Arena logo)
        gsap.to(header, { backgroundColor: "#ffffff", borderBottomColor: "rgba(0,0,0,0.1)", paddingTop: "1rem", paddingBottom: "1rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 0.75, duration: 0.3, ease: "power2.out" });
        gsap.to(logoMain, { opacity: 0, duration: 0.3 });
        gsap.to(logoArena, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#000000", duration: 0.3 });
      },
      onEnterBack: () => {
        // Revert header to transparent, hide Arena logo, show Main logo
        gsap.to(header, { backgroundColor: "transparent", borderBottomColor: "transparent", paddingTop: "1.5rem", paddingBottom: "1.5rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 1, duration: 0.3, ease: "power2.out" });
        gsap.to(logoArena, { opacity: 0, duration: 0.3 });
        gsap.to(logoMain, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#ffffff", duration: 0.3 });
      },
      onLeaveBack: () => {
        // Return to sticky state (white background, Arena logo)
        gsap.to(header, { backgroundColor: "#ffffff", borderBottomColor: "rgba(0,0,0,0.1)", paddingTop: "1rem", paddingBottom: "1rem", duration: 0.3, ease: "power2.out" });
        gsap.to(logoWrapper, { scale: 0.75, duration: 0.3, ease: "power2.out" });
        gsap.to(logoMain, { opacity: 0, duration: 0.3 });
        gsap.to(logoArena, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#000000", duration: 0.3 });
      }
    });

    // 3. Footer Reversion Behavior
    ScrollTrigger.create({
      trigger: "#footer-spacer",
      start: "top bottom", // when the top of the spacer hits the bottom of the viewport
      onEnter: () => {
        // Revert to transparent background and white logo to match dark footer
        gsap.to(header, { backgroundColor: "transparent", borderBottomColor: "transparent", duration: 0.3, ease: "power2.out" });
        gsap.to(logoArena, { opacity: 0, duration: 0.3 });
        gsap.to(logoMain, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#ffffff", duration: 0.3 });
      },
      onLeaveBack: () => {
        // Return to sticky/white state
        gsap.to(header, { backgroundColor: "#ffffff", borderBottomColor: "rgba(0,0,0,0.1)", duration: 0.3, ease: "power2.out" });
        gsap.to(logoMain, { opacity: 0, duration: 0.3 });
        gsap.to(logoArena, { opacity: 1, duration: 0.3 });
        gsap.to(menuLines, { backgroundColor: "#000000", duration: 0.3 });
      }
    });
  }
</script>
