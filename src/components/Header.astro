---
import { Image } from 'astro:assets';
import logoMain from '../assets/logo-main.png';
import logoArena from '../assets/logo-arena.png';

const forceWhiteHeader = Astro.url.pathname === '/contact' || /^\/villas\/?$/.test(Astro.url.pathname);
---

<header id="site-header" class:list={[
  'absolute top-0 left-0 w-full z-50 flex items-center justify-between px-6 py-6 md:px-12 backdrop-blur-sm transition-colors duration-300',
  forceWhiteHeader ? 'bg-white/95 border-b border-black/10' : 'bg-transparent border-b border-transparent'
]}>
  <div class="flex items-center h-16 md:h-24">
    <a href="/" class="relative block h-full w-auto hover:opacity-80 transition-opacity">
      <div id="logo-wrapper" class="relative block h-full w-auto origin-left transition-transform duration-300">
        <div id="logo-main-container" class:list={[
          'h-full transition-opacity duration-300',
          forceWhiteHeader ? 'opacity-0' : 'opacity-100'
        ]}>
          <Image src={logoMain} alt="Experience Papagayo" class="h-full w-auto object-contain" />
        </div>
        <div id="logo-arena-container" class:list={[
          'absolute left-0 top-0 h-full w-full pointer-events-none transition-opacity duration-300',
          forceWhiteHeader ? 'opacity-100' : 'opacity-0'
        ]}>
          <Image src={logoArena} alt="Experience Papagayo" class="h-full w-auto object-contain" />
        </div>
      </div>
    </a>
  </div>

  <button id="menu-toggle" aria-label="Menu" class="flex flex-col items-center justify-center w-10 h-10 space-y-1.5 focus:outline-none group">
    <span class:list={[
      'menu-line block w-6 h-[1px] origin-center transition-colors',
      forceWhiteHeader ? 'bg-[#C9A16A]' : 'bg-white'
    ]}></span>
    <span class:list={[
      'menu-line block w-6 h-[1px] origin-center transition-colors',
      forceWhiteHeader ? 'bg-[#C9A16A]' : 'bg-white'
    ]}></span>
  </button>
</header>
