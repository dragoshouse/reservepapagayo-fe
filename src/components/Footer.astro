---

<footer class="bg-[#EAE8E1] text-black pt-32 lg:pt-48 pb-8 px-6 md:px-12 relative z-10 w-full flex flex-col" data-theme="light">

  <div class="max-w-[1920px] mx-auto w-full flex-grow flex flex-col justify-between">
    <!-- Tier 1: The Information Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 mb-32 lg:mb-48 w-full">

      <!-- Left Column: Inquiries -->
      <div class="lg:col-span-8 flex flex-col items-start space-y-12">
        <div>
          <span class="text-[10px] md:text-xs uppercase tracking-[0.25em] text-black/50 mb-6 block font-medium">Inquiries</span>
          <div class="flex flex-col space-y-6">
            <a href="mailto:reservations@experiencepapagayo.com" class="text-4xl md:text-6xl lg:text-7xl font-serif text-black hover:opacity-50 transition-opacity duration-700 ease-in-out break-all lg:break-normal leading-tight">
              reservations@experiencepapagayo.com
            </a>
            <a href="tel:+50688603621" class="text-4xl md:text-6xl lg:text-7xl font-serif text-black hover:opacity-50 transition-opacity duration-700 ease-in-out leading-tight">
              +(506) 8860-3621
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: Social -->
      <div class="lg:col-span-4 flex flex-col items-start lg:items-end lg:text-right">
        <div class="flex flex-col items-start lg:items-end">
          <span class="text-[10px] md:text-xs uppercase tracking-[0.25em] text-black/50 mb-6 block font-medium">Social</span>
          <!-- Awwwards style animated underline link -->
          <a href="#" target="_blank" class="text-4xl md:text-6xl lg:text-7xl font-serif text-black relative group overflow-hidden pb-2 lg:pb-3 inline-block">
            Instagram
            <span class="absolute bottom-0 left-0 w-full h-[1px] bg-black transform origin-right scale-x-0 group-hover:scale-x-100 group-hover:origin-left transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]"></span>
          </a>
        </div>
      </div>

    </div>

    <!-- Tier 2: The Anchor (Giant Wordmark) -->
    <div class="w-full flex justify-center items-center overflow-hidden pointer-events-none select-none mt-auto">
      <h2 class="text-[18vw] leading-[0.75] font-serif tracking-tighter text-black m-0 p-0 w-full text-center">
        PAPAGAYO
      </h2>
    </div>

    <!-- Tier 3: The Base (Credits) -->
    <div class="w-full mt-12 lg:mt-16 border-t border-black/10 pt-6 flex flex-col md:flex-row justify-between items-center text-[10px] md:text-xs uppercase tracking-[0.2em] text-black/60 gap-4 md:gap-0 font-medium">
      <p>© 2026 EXPERIENCE PAPAGAYO</p>
      <p class="hover:text-black transition-colors duration-500 cursor-pointer">DESIGNED BY DRAGO'S HOUSE</p>
    </div>
  </div>

</footer>
