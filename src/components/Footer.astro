---
import { sanityClient } from "sanity:client";

const query = `*[_type == "siteSettings"][0]`;
let sanityData = null;
try {
  sanityData = await sanityClient.fetch(query);
} catch (e) {
  console.warn("Sanity fetch failed for Footer, using fallbacks.");
}

const addressLines = sanityData?.visitUsAddressLines?.length > 0 ? sanityData.visitUsAddressLines : ["Peninsula Papagayo", "Guanacaste Province", "Costa Rica, 50503"];
const emailLabel = sanityData?.visitUsEmail ?? "reserve@papagayo.com";
const phoneLabel = sanityData?.visitUsPhone ?? "+506 2690 1234";
const socials = sanityData?.socials?.length > 0 ? sanityData.socials : [ { platformName: "Instagram", url: "#" }, { platformName: "Twitter", url: "#" }, { platformName: "LinkedIn", url: "#" } ];
const legalLinks = sanityData?.legalLinks?.length > 0 ? sanityData.legalLinks : [ { label: "Privacy Policy", url: "#" }, { label: "Terms of Service", url: "#" }, { label: "Cookies Policy", url: "#" } ];
const watermarkText = sanityData?.brandWatermarkText ?? "PAPAGAYO";
---

<footer class="footer-wrapper fixed bottom-0 left-0 w-full z-0 bg-[#E0E0D0] text-[#1A1A1A] h-[100vh] flex flex-col justify-between pt-24 pb-8 px-4 md:px-12 pointer-events-none" id="footer" data-theme="light">
  <!-- Content Container (Grid) -->
  <div class="footer-content max-w-7xl mx-auto w-full grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 flex-grow pointer-events-auto">
    <!-- Contact Info -->
    <div class="col-span-1 md:col-span-2">
      <h4 class="text-xs tracking-[0.2em] uppercase font-bold mb-6 border-b border-black/10 pb-4 inline-block">Visit Us</h4>
      <address class="not-italic text-sm leading-loose">
        {addressLines.map((line, index) => (
          <>
            {line}
            {index < addressLines.length - 1 && <br />}
          </>
        ))}
      </address>
      <div class="mt-8 space-y-2 text-sm">
        <a href={`mailto:${emailLabel}`} class="block hover:text-black/60 transition-colors">{emailLabel}</a>
        <a href={`tel:${phoneLabel.replace(/\s+/g, '')}`} class="block hover:text-black/60 transition-colors">{phoneLabel}</a>
      </div>
    </div>

    <!-- Socials -->
    <div class="col-span-1">
      <h4 class="text-xs tracking-[0.2em] uppercase font-bold mb-6 border-b border-black/10 pb-4 inline-block">Socials</h4>
      <ul class="space-y-4 text-sm font-medium">
        {socials.map((item) => (
          <li>
            <a href={item.url} class="hover:text-black/60 transition-colors inline-block relative overflow-hidden group">
              <span class="block transition-transform duration-300 group-hover:-translate-y-full">{item.platformName}</span>
              <span class="block absolute top-full left-0 transition-transform duration-300 group-hover:-translate-y-full text-black/60">{item.platformName}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Legal -->
    <div class="col-span-1">
      <h4 class="text-xs tracking-[0.2em] uppercase font-bold mb-6 border-b border-black/10 pb-4 inline-block">Legal</h4>
      <ul class="space-y-4 text-sm text-black/60">
        {legalLinks.map((item) => (
          <li><a href={item.url} class="hover:text-black transition-colors">{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Massive Watermark -->
  <div class="footer-watermark w-full mt-auto pt-12 overflow-hidden pointer-events-auto">
    <h1 class="font-serif text-[18vw] leading-[0.8] tracking-tighter text-center text-[#1A1A1A] opacity-90 mx-[-2vw]">
      {watermarkText}
    </h1>
    <div class="flex justify-between items-center text-[10px] uppercase tracking-widest border-t border-black/20 pt-4 mt-8 opacity-50">
      <span>&copy; {new Date().getFullYear()} Experience Papagayo.</span>
      <span>Designed with Astro.</span>
    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initFooterParallax() {
    const footer = document.querySelector('.footer-wrapper') as HTMLElement;
    const mainWrap = document.querySelector('.main-content-wrap') as HTMLElement; // Needs to exist in Layout/index

    if (!footer || !mainWrap) return;

    // Create a ScrollTrigger that pins the main content
    // Actually, a simpler way is just to let the main content have relative z-10
    // and margin-bottom equal to the footer height. The footer sits fixed underneath.

    // Instead of complex GSAP, we use a simple spacer to allow scroll
    let spacer = document.getElementById('footer-spacer');
    if (!spacer) {
      spacer = document.createElement('div');
      spacer.id = 'footer-spacer';
      // Append it to the body or main, we'll let index.astro handle the spacing but just in case
      // document.body.appendChild(spacer);
    }

    function setSpacerHeight() {
      if (spacer && footer) {
        spacer.style.height = `${footer.offsetHeight}px`;
      }
    }

    // Only necessary if we dynamically resize
    window.addEventListener('resize', setSpacerHeight);
    setSpacerHeight();

    // Subtle parallax effect on the watermark
    const watermark = footer.querySelector('h1');
    if (watermark) {
      gsap.fromTo(watermark,
        { y: 100, opacity: 0 },
        {
          y: 0,
          opacity: 0.9,
          ease: "power2.out",
          scrollTrigger: {
            trigger: spacer, // use the spacer as the trigger point
            start: "top bottom",
            end: "bottom bottom",
            scrub: 1
          }
        }
      );
    }
  }

  document.addEventListener('astro:page-load', initFooterParallax);
  initFooterParallax();
</script>
