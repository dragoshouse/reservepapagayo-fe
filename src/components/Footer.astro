<footer class="bg-[#EAE8E1] text-black pt-32 pb-8 px-6 md:px-12 relative z-10 w-full" data-theme="light">

  <!-- Tier 1: The Information Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-8 mb-32 max-w-screen-2xl mx-auto">

    <!-- Left Column: Inquiries -->
    <div class="flex flex-col items-start">
      <span class="text-[10px] md:text-xs uppercase tracking-widest text-black/40 mb-6 font-semibold">Inquiries</span>
      <a href="mailto:reservations@experiencepapagayo.com" class="text-2xl md:text-4xl font-serif hover:opacity-60 transition-opacity duration-500 mb-4">
        reservations@experiencepapagayo.com
      </a>
      <a href="tel:+50688603621" class="text-2xl md:text-4xl font-serif hover:opacity-60 transition-opacity duration-500">
        +(506) 8860-3621
      </a>
    </div>

    <!-- Right Column: Social -->
    <div class="flex flex-col items-start md:items-end mt-12 md:mt-0">
      <span class="text-[10px] md:text-xs uppercase tracking-widest text-black/40 mb-6 font-semibold">Social</span>
      <!-- Awwwards style animated underline link -->
      <a href="#" target="_blank" class="text-2xl md:text-4xl font-serif relative group overflow-hidden pb-2">
        Instagram
        <span class="absolute bottom-0 left-0 w-full h-[1px] bg-black transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out"></span>
      </a>
    </div>
  </div>

  <!-- Tier 2: The Anchor (Giant Wordmark) -->
  <div class="w-full flex justify-center items-center mb-16 overflow-hidden pointer-events-none select-none">
    <h2 class="text-[16vw] leading-none font-serif tracking-tighter text-black/90 m-0 p-0">
      PAPAGAYO
    </h2>
  </div>

  <!-- Tier 3: The Base (Credits) -->
  <div class="w-full max-w-screen-2xl mx-auto border-t border-black/15 pt-8 flex flex-col md:flex-row justify-between items-center text-[10px] md:text-xs uppercase tracking-widest text-black/50 gap-4 md:gap-0">
    <p>© 2026 EXPERIENCE PAPAGAYO.</p>
    <p class="hover:text-black transition-colors duration-300 cursor-pointer">DESIGNED BY DRAGO'S HOUSE</p>
  </div>

</footer>
