---
const papagayoLinks = [
  { label: 'About', href: '/about' },
  { label: 'The Peninsula', href: '/the-peninsula' },
  { label: 'Experiences', href: '/#experiences' },
  { label: 'Contact', href: '/contact' },
];

const villaLinks = [
  { label: 'Esmeralda', href: '/villas/villa-esmeralda' },
  { label: 'The Hive', href: '/villas/the-hive' },
  { label: 'Treehouse', href: '/villas/treehouse' },
  { label: 'Casa Coral', href: '/villas/casa-coral' },
];

const socialLinks = [
  { label: 'Instagram', href: '#' },
  { label: 'LinkedIn', href: '#' },
];

const linkClass = 'text-xs font-medium uppercase tracking-[0.24em] text-black/60 transition-colors duration-500 ease-out hover:text-black';
---

<footer id="site-footer" class="relative z-10 w-full bg-[#EAE8E1] px-8 py-24 text-black md:px-12" data-theme="light">
  <div class="mx-auto w-full max-w-[1920px]">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      <div class="footer-col">
        <a href="/" class="block max-w-xs font-serif text-3xl leading-none tracking-[-0.03em] text-black transition-opacity duration-500 hover:opacity-70 md:text-4xl" aria-label="Experience Papagayo home">
          EXPERIENCE PAPAGAYO
        </a>
        <p class="mt-6 max-w-[18rem] text-sm leading-relaxed text-black/60 md:text-base">
          Destination living, redefined.
        </p>
      </div>

      <nav class="footer-col" aria-label="Papagayo footer navigation">
        <h2 class="font-serif text-2xl leading-none tracking-[-0.02em] text-black md:text-3xl">Papagayo</h2>
        <ul class="mt-8 space-y-4">
          {papagayoLinks.map((link) => (
            <li>
              <a href={link.href} class={linkClass}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Villas footer navigation">
        <h2 class="font-serif text-2xl leading-none tracking-[-0.02em] text-black md:text-3xl">Villas</h2>
        <ul class="mt-8 space-y-4">
          {villaLinks.map((link) => (
            <li>
              <a href={link.href} class={linkClass}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Social links">
        <h2 class="font-serif text-2xl leading-none tracking-[-0.02em] text-black md:text-3xl">Follow us</h2>
        <ul class="mt-8 space-y-4">
          {socialLinks.map((link) => (
            <li>
              <a href={link.href} class={linkClass} target="_blank" rel="noopener noreferrer">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="footer-col mt-20 border-t border-black/10 pt-8 md:mt-24">
      <div class="flex flex-col gap-6 text-xs font-medium uppercase tracking-[0.24em] text-black/60 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
          <a href="#" class="transition-colors duration-500 hover:text-black">Cookie Information</a>
          <p>© 2026 Experience Papagayo</p>
        </div>
        <a href="#" class="transition-colors duration-500 hover:text-black">Designed by Drago&apos;s House</a>
      </div>
    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const footer = document.querySelector('#site-footer');
  const footerColumns = gsap.utils.toArray<HTMLElement>('#site-footer .footer-col');

  if (footer && footerColumns.length) {
    gsap.fromTo(
      footerColumns,
      { y: 40, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        stagger: 0.15,
        scrollTrigger: {
          trigger: footer,
          start: 'top 85%',
          once: true,
        },
      }
    );
  }
</script>
