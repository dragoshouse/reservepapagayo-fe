---
import { Picture } from 'astro:assets';
import villaImage from '../assets/feature-villa.jpg';
import culinaryImage from '../assets/exp-culinary.jpg';
import spaImage from '../assets/exp-spa.jpg';
---

<section id="about-rooted" class="py-24 md:py-48 px-6 md:px-12 bg-[#F5F5F0] text-black relative z-10" data-theme="light">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-32 items-start">

    <!-- Left Column: Sticky Text -->
    <div class="md:sticky md:top-[20vh] flex flex-col gap-8 md:pr-12">
      <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl leading-tight">
        Rooted in Peninsula Papagayo
      </h2>
      <div class="text-lg md:text-xl font-light leading-relaxed text-gray-800 space-y-6">
        <p>
          We manage the finest collection of exclusive private sanctuaries on the peninsula. Our properties are hand-selected not just for their architecture or views, but for their ability to provide absolute privacy and tranquility.
        </p>
        <p>
          From the Arnold Palmer Signature golf course to the deep-sea fishing at Marina Papagayo, we provide unprecedented access to the absolute best the region has to offer, curated entirely around your preferences.
        </p>
      </div>
    </div>

    <!-- Right Column: Scrolling Images -->
    <div class="flex flex-col gap-12 md:gap-24 md:pt-16">
      <div class="rounded-xl overflow-hidden shadow-2xl relative w-full aspect-[4/5] md:aspect-auto md:h-[600px]">
        <Picture
          src={villaImage}
          alt="Exclusive private sanctuary exterior"
          formats={['avif', 'webp']}
          class="w-full h-full object-cover"
        />
      </div>

      <div class="rounded-xl overflow-hidden shadow-2xl relative w-full aspect-[4/5] md:aspect-auto md:h-[600px]">
        <Picture
          src={culinaryImage}
          alt="Curated culinary experience"
          formats={['avif', 'webp']}
          class="w-full h-full object-cover"
        />
      </div>

      <div class="rounded-xl overflow-hidden shadow-2xl relative w-full aspect-[4/5] md:aspect-auto md:h-[600px]">
        <Picture
          src={spaImage}
          alt="Exclusive spa and wellness"
          formats={['avif', 'webp']}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

  </div>
</section>
