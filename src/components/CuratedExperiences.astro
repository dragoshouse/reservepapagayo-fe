---
const { sanityData } = Astro.props;

const fallbackExperiences = [
  { id: 1, category: "beach", title: "Prieta Beach Club", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20pg4545RGB%20copy.jpg/:/cr=t:0%25,l:0%25,w:66.68%25,h:100%25/rs=w:388,h:388,cg:true", description: "Offers something for every age, interest, and season, exclusively for guests of Peninsula Papagayo, with an exceptional variety of outdoor adventures, water sports, wellness activities, and year-round classes and events. Its relaxed poolside and beachfront setting combines refined comfort and attentive service with breathtaking natural surroundings." },
  { id: 2, category: "sports", title: "Golf & Tennis", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(GOLF%20)DSC00322_McInnis%20copy.jpg/:/cr=t:0%25,l:16.64%25,w:66.72%25,h:100%25/rs=w:388,h:388,cg:true", description: "Treat yourself to the ultimate eco-golf experience, where every swing is framed by panoramic views of white-sand beaches, turquoise waters, and emerald-green seashore paspalum turf. The 18-hole, par-72 Arnold Palmer Signature Golf Course meanders through lush forests and dramatic valleys." },
  { id: 3, category: "family", title: "Papagayo Park", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/sport%20center.jpeg/:/cr=t:0%25,l:16.38%25,w:67.25%25,h:100%25/rs=w:388,h:388,cg:true", description: "Play, connect, and stay active all in one place. As our guest, you’ll have exclusive access to a vibrant space designed for wellness and community with modern fitness equipment, sports facilities, and kid-friendly areas." },
  { id: 4, category: "family", title: "Kids Club", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20kevsteele_180223_LQ_L10100.jpg/:/cr=t:0%25,l:16.66%25,w:66.68%25,h:100%25/rs=w:388,h:388,cg:true", description: "Designed to broaden your children’s horizons while fostering a deeper appreciation for Costa Rica’s rich culture and natural beauty. With a thoughtful blend of environmental science and the arts, the Club offers a dynamic program of engaging, educational, and imaginative activities." },
  { id: 5, category: "wellness", title: "World-class Spa", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20pg4296RGB%20copy.jpg/:/cr=t:13.14%25,l:0%25,w:100%25,h:73.71%25/rs=w:388,h:388,cg:true", description: "Elevate your stay with exclusive access to the finest resort spas in Peninsula Papagayo. From serene ocean view treatments to curated wellness rituals, every experience is designed to restore, rejuvenate, and inspire." },
  { id: 6, category: "sports", title: "Eco Adventures", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/PAPAGAYO%20EXPLORERS%20CLUB%20)McInnis_073118_66319.jpg/:/cr=t:0%25,l:16.67%25,w:66.67%25,h:100%25/rs=w:388,h:388,cg:true", description: "Make your stay truly unforgettable. Costa Rica is a world-renowned eco-adventure destination, rich in exotic landscapes and extraordinary excursions. Whether you crave the thrill of exploring majestic volcanoes or dream of a private boat journey to a secluded beach." },
  { id: 7, category: "beach", title: "Marina Papagayo", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/blob-0003.png/:/cr=t:0%25,l:16.62%25,w:66.76%25,h:100%25/rs=w:388,h:388,cg:true", description: "Your gateway to untamed splendor. Set out in search of humpback whales, dolphins, and sea turtles, or test your skills in an angler’s paradise teeming with deep-sea gamefish. Cross the gulf to Santa Rosa National Park and ride the legendary waves at Witches Rock." },
  { id: 8, category: "family", title: "Nature Trails", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/polo.jpeg/:/cr=t:10.71%25,l:43.18%25,w:56.82%25,h:89.29%25/rs=w:388,h:388,cg:true,m", description: "Explore quiet paths and lush terrain where families can connect with nature at their own pace." },
  { id: 9, category: "beach", title: "Beaches", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20pg4545RGB%20copy.jpg/:/cr=t:0%25,l:0%25,w:66.68%25,h:100%25/rs=w:388,h:388,cg:true", description: "Spend your days between calm coves and sweeping Pacific shorelines, with beach moments curated around your rhythm." },
  { id: 10, category: "dining", title: "Signature Dining Venues", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20pg4296RGB%20copy.jpg/:/cr=t:13.14%25,l:0%25,w:100%25,h:73.71%25/rs=w:388,h:388,cg:true", description: "Enjoy destination dining that pairs exceptional cuisine with unforgettable coastal settings." },
  { id: 11, category: "dining", title: "Private Chef in Your Villa", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20kevsteele_180223_LQ_L10100.jpg/:/cr=t:0%25,l:16.66%25,w:66.68%25,h:100%25/rs=w:388,h:388,cg:true", description: "Elevate evenings at home with bespoke menus, private service, and restaurant-level culinary experiences in your villa." },
  { id: 12, category: "wellness", title: "Sunset Picnics", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/blob-0003.png/:/cr=t:0%25,l:16.62%25,w:66.76%25,h:100%25/rs=w:388,h:388,cg:true", description: "Unwind at golden hour with thoughtfully prepared seaside picnics in serene, scenic locations." },
  { id: 13, category: "wellness", title: "Wellness Rituals", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/(PRIETA%20BEACH%20CLUB)%20pg4296RGB%20copy.jpg/:/cr=t:13.14%25,l:0%25,w:100%25,h:73.71%25/rs=w:388,h:388,cg:true", description: "Restore body and mind through personalized rituals inspired by the natural rhythm of the peninsula." },
  { id: 14, category: "sports", title: "Surf", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/PAPAGAYO%20EXPLORERS%20CLUB%20)McInnis_073118_66319.jpg/:/cr=t:0%25,l:16.67%25,w:66.67%25,h:100%25/rs=w:388,h:388,cg:true", description: "Chase world-class waves with guided surf outings tailored to your skill level and style." },
  { id: 15, category: "family", title: "Bike Trails", image: "https://img1.wsimg.com/isteam/ip/594de56d-d21f-446f-a9a0-cc641c5dd71e/sport%20center.jpeg/:/cr=t:0%25,l:16.38%25,w:67.25%25,h:100%25/rs=w:388,h:388,cg:true", description: "Discover scenic bike routes perfect for family rides, nature breaks, and active afternoons together." }
];

const displayExperiences = (sanityData?.experiencesGrid && sanityData.experiencesGrid.length > 0)
  ? sanityData.experiencesGrid
  : fallbackExperiences;

const sectionTitle = sanityData?.sectionTitle || "More than a place to stay";
const sectionBody = sanityData?.sectionBody || "A dedicated concierge, daily service, and curated experiences—designed to make every moment effortless.";

const getExperienceValue = (item: any, index: number, key: "title" | "category" | "description") => {
  return item?.[key] || fallbackExperiences[index % fallbackExperiences.length]?.[key] || "";
};

const getExperienceImage = (item: any, index: number) => {
  return item?.imageUrl || item?.image || fallbackExperiences[index % fallbackExperiences.length]?.image || "";
};

const categories = [
  { id: "all", label: "All Experiences" },
  { id: "beach", label: "Beach & Marina" },
  { id: "family", label: "Family" },
  { id: "wellness", label: "Wellness & Spa" },
  { id: "dining", label: "Dining" },
  { id: "sports", label: "Sports & Activities" }
];

const getGridClasses = (index: number) => {
  switch (index) {
    case 0:
    case 3:
    case 4:
    case 7:
      return "col-span-1 row-span-1";
    case 1:
      return "md:col-span-2 row-span-1";
    case 2:
      return "row-span-2";
    case 5:
      return "col-span-1 row-span-1";
    case 6:
      return "md:col-span-2 md:row-span-2";
    default:
      return "col-span-1 row-span-1";
  }
};
---

<section data-theme="light" class="bg-white py-24 text-black">
  <div class="container mx-auto px-4 max-w-7xl">
    <h2 class="text-4xl md:text-5xl font-serif text-center mb-16 uppercase tracking-widest text-black">
      {sectionTitle}
    </h2>
    <p class="max-w-3xl mx-auto text-center text-lg md:text-xl text-black/60 font-light leading-relaxed mb-16">
      {sectionBody}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 auto-rows-[300px] mb-16" id="bento-grid">
      {displayExperiences.map((exp, index) => {
        const title = getExperienceValue(exp, index, "title");
        const category = getExperienceValue(exp, index, "category");
        const description = getExperienceValue(exp, index, "description");
        const image = getExperienceImage(exp, index);

        return (
        <div
          class={`experience-card cursor-pointer relative overflow-hidden group rounded-none ${getGridClasses(index)} bg-gray-100`}
          data-category={category}
          data-title={title}
          data-description={description}
          data-image={image}
        >
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center p-6 text-center">
            <h3 class="text-white text-2xl md:text-3xl font-serif tracking-wide">{title}</h3>
          </div>
        </div>
        );
      })}
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      {categories.map((cat) => (
        <button
          class="filter-btn px-6 py-2 border border-black text-black hover:bg-black hover:text-white transition-colors duration-300 uppercase tracking-widest text-sm rounded-full"
          data-filter={cat.id}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Modal -->
<div id="experience-modal" class="fixed inset-0 z-[99999] hidden opacity-0 pointer-events-none items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="relative bg-white max-w-3xl w-full max-h-[90vh] overflow-y-auto overflow-x-hidden rounded-2xl shadow-2xl flex flex-col md:flex-row transform scale-95 opacity-0" id="modal-content">
    <button id="modal-close" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center bg-white/80 hover:bg-white text-black transition-colors rounded-full" aria-label="Close modal">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="w-full md:w-1/2 h-64 md:h-auto">
      <img id="modal-image" src="" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
      <h3 id="modal-title" class="text-3xl font-serif mb-6 text-black uppercase tracking-wide"></h3>
      <p id="modal-description" class="text-gray-600 leading-relaxed font-sans"></p>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const initExperiences = () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.experience-card');
    const modal = document.getElementById('experience-modal');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const modalContent = document.getElementById('modal-content');
    const modalClose = document.getElementById('modal-close');
    const modalImage = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title');
    const modalDescription = document.getElementById('modal-description');

    // Set initial active state for 'all' filter
    const allBtn = document.querySelector('[data-filter="all"]');
    if (allBtn) {
      allBtn.classList.add('bg-black', 'text-white');
    }

    // Filtering logic
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update button styles
        filterBtns.forEach(b => b.classList.remove('bg-black', 'text-white'));
        btn.classList.add('bg-black', 'text-white');

        const filter = btn.getAttribute('data-filter');

        const visibleCards: Element[] = [];
        const hiddenCards: Element[] = [];

        cards.forEach(card => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || filter === category) {
            visibleCards.push(card);
          } else {
            hiddenCards.push(card);
          }
        });

        // Hide cards not in category
        if (hiddenCards.length > 0) {
          gsap.to(hiddenCards, {
            opacity: 0,
            scale: 0.9,
            duration: 0.4,
            ease: "power2.inOut",
            onComplete: () => {
              hiddenCards.forEach(card => {
                (card as HTMLElement).style.display = 'none';
              });

              // Show visible cards after hiding others
              if (visibleCards.length > 0) {
                visibleCards.forEach(card => {
                  (card as HTMLElement).style.display = 'block';
                });

                // Allow browser to render display block before animating opacity
                requestAnimationFrame(() => {
                  gsap.to(visibleCards, {
                    opacity: 1,
                    scale: 1,
                    duration: 0.4,
                    ease: "power2.out"
                  });
                });
              }
            }
          });
        } else {
          // All cards visible (e.g. going from a filter to 'all')
          visibleCards.forEach(card => {
            (card as HTMLElement).style.display = 'block';
          });

          requestAnimationFrame(() => {
            gsap.to(visibleCards, {
              opacity: 1,
              scale: 1,
              duration: 0.4,
              ease: "power2.out"
            });
          });
        }
      });
    });

    // Modal logic
    const openModal = (card: HTMLElement) => {
      const title = card.getAttribute('data-title') || '';
      const desc = card.getAttribute('data-description') || '';
      const img = card.getAttribute('data-image') || '';

      if (modalImage) modalImage.src = img;
      if (modalTitle) modalTitle.textContent = title;
      if (modalDescription) modalDescription.textContent = desc;
      if (modalImage) modalImage.alt = title;

      if (modal && modalContent) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        // Small delay to allow display to take effect before animating opacity
        requestAnimationFrame(() => {
          gsap.to(modal, { opacity: 1, duration: 0.3, pointerEvents: 'auto' });
          gsap.to(modalContent, { opacity: 1, scale: 1, duration: 0.4, ease: "back.out(1.2)", delay: 0.1 });
          document.body.style.overflow = 'hidden';
        });
      }
    };

    const closeModal = () => {
      if (modal && modalContent) {
        gsap.to(modalContent, { opacity: 0, scale: 0.95, duration: 0.3, ease: "power2.in" });
        gsap.to(modal, {
          opacity: 0,
          duration: 0.3,
          pointerEvents: 'none',
          delay: 0.1,
          onComplete: () => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
            document.body.style.overflow = '';
          }
        });
      }
    };

    cards.forEach(card => {
      card.addEventListener('click', () => openModal(card as HTMLElement));
    });

    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (modalBackdrop) modalBackdrop.addEventListener('click', closeModal);

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  };

  document.addEventListener('DOMContentLoaded', initExperiences);
  document.addEventListener('astro:page-load', initExperiences);
</script>
